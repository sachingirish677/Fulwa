{% liquid
  assign muted_alpha = section.settings.muted_text_opacity | times: 0.01
  assign border_alpha = section.settings.secondary_border_opacity | times: 0.01

  assign transition_ms = section.settings.transition_duration_ms
  assign autoplay_on = section.settings.enable_autoplay
  assign autoplay_ms = section.settings.autoplay_interval | times: 1000

  assign slide_blocks = section.blocks | where: 'type', 'slide'
%}

<section
  class="fulva-hero fulva-hero--{{ section.id }}{% if section.settings.hide_on_mobile %} fulva-hero--hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} fulva-hero--hide-desktop{% endif %}"
  aria-label="{{ section.settings.aria_label | escape }}"
  data-fulva-hero
  style="
    --fh-bg-fallback: {{ section.settings.background_fallback_color }};
    --fh-text: {{ section.settings.text_color }};
    --fh-muted: {{ section.settings.muted_text_color | color_modify: 'alpha', muted_alpha }};
    --fh-accent: {{ section.settings.accent_color }};
    --fh-height: {{ section.settings.height_desktop }}px;
    --fh-height-mobile: {{ section.settings.height_mobile }}px;
    --fh-height-used: max(360px, min({{ section.settings.height_desktop }}px, 62vh));
    --fh-height-mobile-used: max(440px, min({{ section.settings.height_mobile }}px, 56vh));
    --fh-px: {{ section.settings.padding_x_desktop }}px;
    --fh-px-mobile: {{ section.settings.padding_x_mobile }}px;
    --fh-max-width: {% if section.settings.max_width > 0 %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
    --fh-eyebrow-size: {{ section.settings.eyebrow_size }}px;
    --fh-title-size: {{ section.settings.title_size_desktop }}px;
    --fh-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --fh-accent-size: {{ section.settings.accent_size_desktop }}px;
    --fh-accent-size-mobile: {{ section.settings.accent_size_mobile }}px;
    --fh-sub-size: {{ section.settings.subtext_size }}px;
    --fh-btn-py: {{ section.settings.button_padding_y }}px;
    --fh-btn-px: {{ section.settings.button_padding_x }}px;
    --fh-primary-bg: {{ section.settings.primary_bg }};
    --fh-primary-text: {{ section.settings.primary_text }};
    --fh-secondary-border: {{ section.settings.secondary_border | color_modify: 'alpha', border_alpha }};
    --fh-secondary-text: {{ section.settings.secondary_text }};
    --fh-trans: {{ transition_ms }}ms;
    --fh-hover-scale: {{ section.settings.hover_scale | times: 0.01 }};
    --fh-hover-raise: {{ section.settings.hover_raise }}px;
    --fh-float-amp: {{ section.settings.float_amount }}px;
    --fh-float-speed: {{ section.settings.float_duration }}s;
    --fh-img-max: {{ section.settings.image_max_width_desktop }}px;
    --fh-img-max-mobile: {{ section.settings.image_max_width_mobile }}px;
  "
>
  <div class="fulva-hero__bgstage" aria-hidden="true">
    {% if slide_blocks.size > 0 %}
      {% for block in slide_blocks %}
        {% liquid
          assign s_bg_d = block.settings.bg_image_desktop
          assign s_bg_m = block.settings.bg_image_mobile
          assign s_bg_legacy = block.settings.bg_image
          assign s_bg_color = block.settings.bg_fallback_color
          assign s_bg_fit = block.settings.bg_fit
          if s_bg_fit == blank
            assign s_bg_fit = 'cover'
          endif

          assign s_bg_fallback = s_bg_d
          if s_bg_fallback == blank
            assign s_bg_fallback = s_bg_legacy
          endif
          if s_bg_fallback == blank
            assign s_bg_fallback = s_bg_m
          endif

          if s_bg_fallback == blank
            assign s_bg_d = section.settings.background_image_desktop
            assign s_bg_m = section.settings.background_image_mobile
            assign s_bg_legacy = section.settings.background_image
            assign s_bg_color = section.settings.background_fallback_color
            assign s_bg_fit = section.settings.background_fit
            if s_bg_fit == blank
              assign s_bg_fit = 'cover'
            endif

            assign s_bg_fallback = s_bg_d
            if s_bg_fallback == blank
              assign s_bg_fallback = s_bg_legacy
            endif
            if s_bg_fallback == blank
              assign s_bg_fallback = s_bg_m
            endif
          endif

          assign s_pos_d = '50% 50%'
          assign s_pos_m = '50% 50%'

          if s_bg_d != blank and s_bg_d.presentation.focal_point != blank
            assign s_pos_d = s_bg_d.presentation.focal_point
          elsif s_bg_fallback != blank and s_bg_fallback.presentation.focal_point != blank
            assign s_pos_d = s_bg_fallback.presentation.focal_point
          endif

          if s_bg_m != blank and s_bg_m.presentation.focal_point != blank
            assign s_pos_m = s_bg_m.presentation.focal_point
          elsif s_bg_fallback != blank and s_bg_fallback.presentation.focal_point != blank
            assign s_pos_m = s_bg_fallback.presentation.focal_point
          endif
        %}

        <div class="fulva-hero__bgslide{% if s_bg_fit == 'contain' %} is-bg-contain{% endif %}{% if forloop.first %} is-active{% endif %}" data-fulva-hero-bg data-index="{{ forloop.index0 }}" style="--fhs-bg: {{ s_bg_color }}; --fhs-bg-pos-d: {{ s_pos_d }}; --fhs-bg-pos-m: {{ s_pos_m }};">
          <div class="fulva-hero__bg-fill"></div>
          {% if s_bg_fallback != blank %}
            <picture class="fulva-hero__bg-picture">
              {% if s_bg_m != blank %}
                <source
                  media="(max-width: 989px)"
                  srcset="
                    {{ s_bg_m | image_url: width: 750 }} 750w,
                    {{ s_bg_m | image_url: width: 1000 }} 1000w,
                    {{ s_bg_m | image_url: width: 1300 }} 1300w,
                    {{ s_bg_m | image_url: width: 1600 }} 1600w
                  "
                  sizes="100vw"
                >
              {% endif %}
              {% if s_bg_d != blank %}
                <source
                  media="(min-width: 990px)"
                  srcset="
                    {{ s_bg_d | image_url: width: 1200 }} 1200w,
                    {{ s_bg_d | image_url: width: 1600 }} 1600w,
                    {{ s_bg_d | image_url: width: 2000 }} 2000w,
                    {{ s_bg_d | image_url: width: 2400 }} 2400w
                  "
                  sizes="100vw"
                >
              {% endif %}
              <img
                class="fulva-hero__bg-img"
                src="{{ s_bg_fallback | image_url: width: 2000 }}"
                width="{{ s_bg_fallback.width }}"
                height="{{ s_bg_fallback.height }}"
                alt=""
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                {% if forloop.first %}fetchpriority="high"{% endif %}
                decoding="async"
              >
            </picture>
          {% endif %}
        </div>
      {% endfor %}
    {% endif %}
  </div>

  <div class="fulva-hero__container">
    <div class="fulva-hero__stage" data-fulva-hero-stage>
      {% if slide_blocks.size == 0 %}
        <div class="fulva-hero__empty">{{ section.settings.empty_state_text | escape }}</div>
      {% else %}
        {% for block in slide_blocks %}
          <div class="fulva-hero__slide{% if forloop.first %} is-active{% endif %}" data-fulva-hero-slide data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <div class="fulva-hero__grid">
              <div class="fulva-hero__text-group">
                {% if block.settings.eyebrow_text != blank %}
                  <div class="fulva-hero__eyebrow">{{ block.settings.eyebrow_text | escape }}</div>
                {% endif %}

                {% if block.settings.title_text != blank or block.settings.accent_text != blank %}
                  <h2 class="fulva-hero__title">
                    {% if block.settings.title_text != blank %}
                      {{ block.settings.title_text }}
                    {% endif %}
                    {% if block.settings.accent_text != blank %}
                      <span class="fulva-hero__accent">{{ block.settings.accent_text }}</span>
                    {% endif %}
                  </h2>
                {% endif %}

                {% if block.settings.subtext != blank %}
                  <div class="fulva-hero__sub">{{ block.settings.subtext }}</div>
                {% endif %}
              </div>

              <div class="fulva-hero__media">
                <div class="fulva-hero__image-wrap{% if section.settings.enable_float %} is-floating{% endif %}">
                  {% liquid
                    assign hero_img = block.settings.image
                    if hero_img == blank
                      assign hero_img = section.settings.hero_image
                    endif
                  %}
                  <div class="fulva-hero__image-inner">
                    {% if hero_img != blank %}
                      <img
                        class="fulva-hero__image"
                        src="{{ hero_img | image_url: width: 1600 }}"
                        srcset="
                          {{ hero_img | image_url: width: 600 }} 600w,
                          {{ hero_img | image_url: width: 900 }} 900w,
                          {{ hero_img | image_url: width: 1200 }} 1200w,
                          {{ hero_img | image_url: width: 1600 }} 1600w
                        "
                        sizes="(min-width: 990px) 55vw, 100vw"
                        width="{{ hero_img.width }}"
                        height="{{ hero_img.height }}"
                        alt="{{ hero_img.alt | escape }}"
                        loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                        {% if forloop.first %}fetchpriority="high"{% endif %}
                      >
                    {% else %}
                      <div class="fulva-hero__image-placeholder">{{ block.settings.placeholder_text | escape }}</div>
                    {% endif %}
                  </div>
                </div>
              </div>

              <div class="fulva-hero__bottom-group">
                {% if block.settings.stat_1_number != blank or block.settings.stat_2_number != blank or block.settings.stat_3_number != blank %}
                  <div class="fulva-hero__stats" role="list">
                    {% if block.settings.stat_1_number != blank %}
                      <div class="fulva-hero__stat" role="listitem">
                        <div class="fulva-hero__stat-num">{{ block.settings.stat_1_number | escape }}</div>
                        {% if block.settings.stat_1_label != blank %}
                          <div class="fulva-hero__stat-label">{{ block.settings.stat_1_label | escape }}</div>
                        {% endif %}
                      </div>
                    {% endif %}
                    {% if block.settings.stat_2_number != blank %}
                      <div class="fulva-hero__stat" role="listitem">
                        <div class="fulva-hero__stat-num">{{ block.settings.stat_2_number | escape }}</div>
                        {% if block.settings.stat_2_label != blank %}
                          <div class="fulva-hero__stat-label">{{ block.settings.stat_2_label | escape }}</div>
                        {% endif %}
                      </div>
                    {% endif %}
                    {% if block.settings.stat_3_number != blank %}
                      <div class="fulva-hero__stat" role="listitem">
                        <div class="fulva-hero__stat-num">{{ block.settings.stat_3_number | escape }}</div>
                        {% if block.settings.stat_3_label != blank %}
                          <div class="fulva-hero__stat-label">{{ block.settings.stat_3_label | escape }}</div>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.primary_label != blank or block.settings.secondary_label != blank %}
                  <div class="fulva-hero__actions">
                    {% if block.settings.primary_label != blank and block.settings.primary_url != blank %}
                      <a class="fulva-hero__btn is-primary" href="{{ block.settings.primary_url }}">{{ block.settings.primary_label | escape }}</a>
                    {% endif %}
                    {% if block.settings.secondary_label != blank and block.settings.secondary_url != blank %}
                      <a class="fulva-hero__btn is-secondary" href="{{ block.settings.secondary_url }}">{{ block.settings.secondary_label | escape }}</a>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_bottom_controls and slide_blocks.size > 1 %}
      <div class="fulva-hero__bottom" aria-label="Hero controls">
        <div class="fulva-hero__bottom-left" role="tablist" aria-label="Slides">
          {% for block in slide_blocks %}
            <button
              class="fulva-hero__dot{% if forloop.first %} is-active{% endif %}"
              type="button"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Go to slide {{ forloop.index }}"
              data-fulva-hero-dot
              data-index="{{ forloop.index0 }}"
            ></button>
          {% endfor %}
        </div>
        <div class="fulva-hero__bottom-right">
          <button class="fulva-hero__arrow" type="button" aria-label="Previous slide" data-fulva-hero-prev>
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M14.7 5.3a1 1 0 0 1 0 1.4L9.4 12l5.3 5.3a1 1 0 1 1-1.4 1.4l-6-6a1 1 0 0 1 0-1.4l6-6a1 1 0 0 1 1.4 0z"></path>
            </svg>
          </button>
          <button class="fulva-hero__arrow" type="button" aria-label="Next slide" data-fulva-hero-next>
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9.3 18.7a1 1 0 0 1 0-1.4L14.6 12 9.3 6.7a1 1 0 1 1 1.4-1.4l6 6a1 1 0 0 1 0 1.4l-6 6a1 1 0 0 1-1.4 0z"></path>
            </svg>
          </button>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .fulva-hero--{{ section.id }} {
    color: var(--fh-text);
    font-family: var(--font-body-family, inherit);
    font-style: var(--font-body-style, normal);
    position: relative;
    overflow: hidden;
    background: var(--fh-bg-fallback);
    --fh-title-size-used: clamp(34px, calc(var(--fh-height-used) * 0.09), var(--fh-title-size));
    --fh-accent-size-used: clamp(38px, calc(var(--fh-height-used) * 0.10), var(--fh-accent-size));
    --fh-sub-size-used: clamp(13px, calc(var(--fh-height-used) * 0.018), var(--fh-sub-size));
    --fh-title-size-mobile-used: clamp(28px, calc(var(--fh-height-mobile-used) * 0.075), var(--fh-title-size-mobile));
    --fh-accent-size-mobile-used: clamp(32px, calc(var(--fh-height-mobile-used) * 0.085), var(--fh-accent-size-mobile));
    --fh-sub-size-mobile-used: clamp(12px, calc(var(--fh-height-mobile-used) * 0.018), var(--fh-sub-size));
  }

  .fulva-hero--{{ section.id }} .fulva-hero__bgstage {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__bgslide {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: var(--fhs-bg, var(--fh-bg-fallback));
    opacity: 0;
    transition: opacity var(--fh-trans) ease;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__bgslide.is-active {
    opacity: 1;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__bg-fill {
    position: absolute;
    inset: 0;
    background: var(--fhs-bg, var(--fh-bg-fallback));
  }

  .fulva-hero--{{ section.id }} .fulva-hero__bg-picture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--fhs-bg-pos-d, 50% 50%);
    transform: translateZ(0);
    z-index: 0;
    display: block;
    background: var(--fhs-bg, var(--fh-bg-fallback));
  }

  .fulva-hero--{{ section.id }} .fulva-hero__bgslide.is-bg-contain .fulva-hero__bg-img {
    object-fit: contain;
  }

  @media (max-width: 989px) {
    .fulva-hero--{{ section.id }} .fulva-hero__bg-img {
      object-position: var(--fhs-bg-pos-m, 50% 50%);
    }
  }

  .fulva-hero--{{ section.id }} .fulva-hero__container {
    width: 100%;
    max-width: var(--fh-max-width);
    margin: 0 auto;
    padding: 0 var(--fh-px);
    position: relative;
    z-index: 5;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__stage {
    position: relative;
    min-height: var(--fh-height-used);
    touch-action: pan-y;
    -webkit-user-select: none;
    user-select: none;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__empty {
    min-height: var(--fh-height-used);
    padding: 44px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    border: 1px dashed rgba(255, 255, 255, 0.28);
    color: var(--fh-muted);
    text-align: center;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__stage > .fulva-hero__slide {
    display: none;
  }

  .fulva-hero--{{ section.id }}:not(.is-init) .fulva-hero__stage > .fulva-hero__slide:first-of-type {
    display: block;
    position: relative;
    opacity: 1;
    pointer-events: auto;
    transform: none;
  }

  .fulva-hero--{{ section.id }}.is-init .fulva-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transform: translate3d(0, 10px, 0);
    transition: opacity var(--fh-trans) ease, transform var(--fh-trans) cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
    contain: layout paint;
  }

  .fulva-hero--{{ section.id }}.is-init .fulva-hero__slide {
    display: block;
  }

  .fulva-hero--{{ section.id }}.is-init .fulva-hero__slide.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translate3d(0, 0, 0);
  }

  .fulva-hero--{{ section.id }}.is-init .fulva-hero__slide.is-active .fulva-hero__text-group,
  .fulva-hero--{{ section.id }}.is-init .fulva-hero__slide.is-active .fulva-hero__bottom-group {
    animation: fulva-hero-content-in-{{ section.id }} var(--fh-trans) ease both;
  }

  .fulva-hero--{{ section.id }}.is-init .fulva-hero__slide.is-active .fulva-hero__image-wrap {
    animation: fulva-hero-media-in-{{ section.id }} calc(var(--fh-trans) + 120ms) ease both;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__grid {
    min-height: var(--fh-height-used);
    display: grid;
    grid-template-columns: 45% 55%;
    grid-template-rows: auto auto;
    align-content: center;
    gap: 0 clamp(16px, calc(var(--fh-height-used) * 0.03), 22px);
    padding: clamp(16px, calc(var(--fh-height-used) * 0.035), 30px) 0;
    position: relative;
    z-index: 2;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__text-group {
    grid-column: 1;
    grid-row: 1;
    max-width: 560px;
    align-self: end;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__bottom-group {
    grid-column: 1;
    grid-row: 2;
    max-width: 560px;
    align-self: start;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--fh-eyebrow-size);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fh-accent);
    font-weight: 600;
    font-family: var(--font-body-family, inherit);
  }

  .fulva-hero--{{ section.id }} .fulva-hero__eyebrow::before {
    content: '';
    width: 28px;
    height: 2px;
    background: var(--fh-accent);
    flex: 0 0 auto;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__title {
    margin: 12px 0 0 0;
    font-family: var(--font-heading-family, inherit);
    font-style: var(--font-heading-style, normal);
    font-weight: var(--font-heading-weight, 700);
    font-size: var(--fh-title-size-used);
    line-height: 1.02;
    color: var(--fh-text);
    position: relative;
    text-shadow: 0 10px 26px rgba(0, 0, 0, 0.38);
    letter-spacing: -0.01em;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__title em {
    font-style: italic;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__title::after {
    content: '';
    display: block;
    width: 56px;
    height: 2px;
    margin-top: 10px;
    background: var(--fh-accent);
    transform-origin: left center;
    transform: scaleX(1);
    opacity: 0.95;
  }

  .fulva-hero--{{ section.id }}.is-init .fulva-hero__slide.is-active .fulva-hero__title::after {
    animation: fulva-hero-title-line-{{ section.id }} calc(var(--fh-trans) + 120ms) ease both;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__accent {
    display: block;
    margin-top: -2px;
    font-style: italic;
    font-weight: var(--font-heading-weight, 700);
    font-size: var(--fh-accent-size-used);
    color: var(--fh-accent);
    filter: drop-shadow(0 10px 22px rgba(0, 0, 0, 0.35));
  }

  .fulva-hero--{{ section.id }} .fulva-hero__accent em {
    font-style: italic;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__sub {
    margin-top: 12px;
    font-size: var(--fh-sub-size-used);
    line-height: 1.7;
    color: var(--fh-muted);
    max-width: 420px;
    font-family: var(--font-body-family, inherit);
  }

  .fulva-hero--{{ section.id }} .fulva-hero__sub p {
    margin: 0;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__actions {
    display: flex;
    gap: 12px;
    margin-top: clamp(12px, calc(var(--fh-height-used) * 0.02), 20px);
    flex-wrap: wrap;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--fh-btn-py) var(--fh-btn-px);
    border-radius: 0;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
    text-decoration: none;
    white-space: nowrap;
    font-family: var(--font-body-family, inherit);
    min-height: 44px;
    transition: transform 160ms ease, filter 160ms ease, background 160ms ease, color 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .fulva-hero--{{ section.id }} .fulva-hero__btn.is-primary {
    background: var(--fh-primary-bg);
    color: var(--fh-primary-text);
    box-shadow: 0 0 18px var(--fh-primary-bg);
    border: 1px solid rgba(0, 0, 0, 0.12);
  }

  .fulva-hero--{{ section.id }} .fulva-hero__btn.is-primary:hover {
    filter: brightness(1.04);
    transform: translateY(-1px);
    box-shadow: 0 0 30px var(--fh-primary-bg);
  }

  .fulva-hero--{{ section.id }} .fulva-hero__btn.is-secondary {
    background: rgba(255, 255, 255, 0.10);
    border: 2px solid var(--fh-secondary-border);
    color: var(--fh-secondary-text);
  }

  .fulva-hero--{{ section.id }} .fulva-hero__btn.is-secondary:hover {
    border-color: var(--fh-text);
    filter: brightness(1.02);
  }

  @media (max-width: 989px) {
    .fulva-hero--{{ section.id }} .fulva-hero__btn.is-secondary {
      background: rgba(255, 255, 255, 0.16);
      border-color: rgba(255, 255, 255, 0.62);
      box-shadow: 0 10px 22px rgba(0, 0, 0, 0.18);
    }
  }

  @keyframes fulva-hero-content-in-{{ section.id }} {
    0% {
