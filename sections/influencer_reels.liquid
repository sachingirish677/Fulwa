{{ 'influencer-reels.css' | asset_url | stylesheet_tag }}
{% liquid
  assign border_alpha = section.settings.border_opacity | times: 0.01
  assign card_border_alpha = section.settings.card_border_opacity | times: 0.01
  assign shadow_alpha = section.settings.shadow_opacity | times: 0.01

  assign buzz_blocks = section.blocks | where: 'type', 'mention'

  assign bg = section.settings.background
  assign bg2 = section.settings.background_2
  assign bg3 = section.settings.background_3
  assign text_color = section.settings.text_color
  assign muted_color = section.settings.muted_text_color
  assign accent_color = section.settings.accent_color
  assign title_highlight = section.settings.title_highlight_color

  if section.settings.use_exact_palette
    assign bg = '#0C6A20'
    assign bg2 = '#064414'
    assign bg3 = '#031A08'
    assign text_color = '#FFFFFF'
    assign muted_color = '#D4E3D7'
    assign accent_color = '#F4C026'
    assign title_highlight = '#F4C026'
  endif
%}

<section
  class="fulva-buzz fulva-buzz--{{ section.id }} fulva-buzz--bg-{{ section.settings.background_style }}{% if section.settings.hide_on_mobile %} fulva-buzz--hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} fulva-buzz--hide-desktop{% endif %}"
  aria-label="{{ section.settings.aria_label | escape }}"
  style="
    --fb-bg: {{ bg }};
    --fb-bg2: {{ bg2 }};
    --fb-bg3: {{ bg3 }};
    --fb-glow1: {{ section.settings.glow_1 }};
    --fb-glow2: {{ section.settings.glow_2 }};
    --fb-text: {{ text_color }};
    --fb-muted: {{ muted_color }};
    --fb-accent: {{ accent_color }};
    --fb-title-highlight: {{ title_highlight }};
    --fb-border: {{ section.settings.border_color | color_modify: 'alpha', border_alpha }};
    --fb-card-bg: {{ section.settings.card_background }};
    --fb-card-border: {{ section.settings.card_border_color | color_modify: 'alpha', card_border_alpha }};
    --fb-shadow: {{ section.settings.shadow_color | color_modify: 'alpha', shadow_alpha }};
    --fb-max: {% if section.settings.max_width > 0 %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
    --fb-px: {{ section.settings.padding_x_desktop }}px;
    --fb-py: {{ section.settings.padding_y_desktop }}px;
    --fb-px-m: {{ section.settings.padding_x_mobile }}px;
    --fb-py-m: {{ section.settings.padding_y_mobile }}px;
    --fb-gap: {{ section.settings.gap }}px;
    --fb-radius: {{ section.settings.radius }}px;
    --fb-card-w: {{ section.settings.card_width_desktop }}px;
    --fb-card-w-m: {{ section.settings.card_width_mobile }}px;
    --fb-card-ar: {{ section.settings.card_aspect_ratio }};
    --fb-media-radius: {{ section.settings.media_radius }}px;
    --fb-stage-h: {{ section.settings.stage_height_desktop }}px;
    --fb-stage-h-m: {{ section.settings.stage_height_mobile }}px;
    --fb-offset: {{ section.settings.slide_offset_desktop }}px;
    --fb-offset-m: {{ section.settings.slide_offset_mobile }}px;
    --fb-mid-scale: {{ section.settings.mid_scale | times: 0.01 }};
    --fb-far-scale: {{ section.settings.far_scale | times: 0.01 }};
    --fb-profile-size: {{ section.settings.profile_size }}px;
  "
>
  <div class="fulva-buzz__inner">
    <header class="fulva-buzz__header">
      {% if section.settings.eyebrow != blank %}
        <div class="fulva-buzz__eyebrow">{{ section.settings.eyebrow | escape }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="fulva-buzz__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.show_subtitle and section.settings.subtitle != blank %}
        <div class="fulva-buzz__subtitle">{{ section.settings.subtitle }}</div>
      {% endif %}
      {% if section.settings.show_cta and section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <a class="fulva-buzz__cta" href="{{ section.settings.cta_link }}" aria-label="{{ section.settings.cta_label | escape }}">
          {{ section.settings.cta_label | escape }}
        </a>
      {% endif %}
    </header>

    {% if section.settings.show_profiles %}
      <div class="fulva-buzz__profiles" role="list" aria-label="Featured people" data-fb-profiles>
        {% for block in buzz_blocks %}
          {% liquid
            assign avatar = block.settings.avatar
            assign name = block.settings.name
            if name == blank
              assign name = 'Creator'
            endif
            assign role = block.settings.title
            if role == blank
              assign role = 'INFLUENCER'
            endif
          %}

          <button class="fulva-buzz__profile" type="button" role="listitem" data-fb-profile data-index="{{ forloop.index0 }}" aria-label="{{ name | escape }}" {{ block.shopify_attributes }}>
            <span class="fulva-buzz__profile-avatar" aria-hidden="{% if avatar != blank %}false{% else %}true{% endif %}">
              {% if avatar != blank %}
                <img
                  class="fulva-buzz__profile-avatar-img"
                  src="{{ avatar | image_url: width: 160 }}"
                  srcset="
                    {{ avatar | image_url: width: 80 }} 80w,
                    {{ avatar | image_url: width: 120 }} 120w,
                    {{ avatar | image_url: width: 160 }} 160w,
                    {{ avatar | image_url: width: 240 }} 240w
                  "
                  sizes="{{ section.settings.profile_size }}px"
                  width="{{ avatar.width }}"
                  height="{{ avatar.height }}"
                  alt="{{ name | escape }}"
                  loading="lazy"
                  decoding="async"
                >
              {% else %}
                <span class="fulva-buzz__profile-avatar-fallback" aria-hidden="true"></span>
              {% endif %}
            </span>
            <span class="fulva-buzz__profile-role">{{ role | escape }}</span>
            <span class="fulva-buzz__profile-name">{{ name | escape }}</span>
          </button>
        {% endfor %}
      </div>
    {% endif %}

    <div class="fulva-buzz__carousel" data-fb-carousel>
      {% if section.settings.show_arrows %}
        <button class="fulva-buzz__carousel-arrow fulva-buzz__carousel-arrow--prev" type="button" aria-label="Previous" data-fb-prev>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
        </button>
      {% endif %}

      <div class="fulva-buzz__stage" data-fb-stage aria-label="{{ section.settings.aria_label | escape }}">
        {% for block in buzz_blocks %}
          {% liquid
            assign primary_link = block.settings.link
            assign video = block.settings.video
            assign instagram_link = block.settings.instagram_link
            assign media = block.settings.media
            assign name = block.settings.name
            if name == blank
              assign name = 'Creator'
            endif
            assign views = block.settings.metric
            if views == blank
              assign views = '1.2M'
            endif
            assign likes = block.settings.like_text
            if likes == blank
              assign likes = '84K'
            endif
          %}

          <div class="fulva-buzz__slide" data-fb-slide data-index="{{ forloop.index0 }}" aria-hidden="true" {{ block.shopify_attributes }}>
            {% if primary_link != blank %}
              <a class="fulva-buzz__slide-link" href="{{ primary_link }}" aria-label="{{ name | escape }}">
            {% endif %}
                <div class="fulva-buzz__slide-media">
                  {% if instagram_link != blank %}
                    {% assign iframe_src = instagram_link %}
                    {% if iframe_src contains '?' %}
                      {% assign iframe_src = iframe_src | split: '?' | first %}
                    {% endif %}
                    {% assign last_char = iframe_src | slice: -1 %}
                    {% if last_char != '/' %}
                      {% assign iframe_src = iframe_src | append: '/' %}
                    {% endif %}
                    {% assign iframe_src = iframe_src | append: 'embed' %}
                    <iframe class="fulva-buzz__slide-iframe" src="{{ iframe_src }}" frameborder="0" scrolling="no" allowtransparency="true" allowfullscreen></iframe>
                  {% elsif video != blank %}
                    {{ video | video_tag: class: 'fulva-buzz__slide-video', autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                  {% elsif media != blank %}
                    <img
                      class="fulva-buzz__slide-img"
                      src="{{ media | image_url: width: 900 }}"
                      srcset="
                        {{ media | image_url: width: 360 }} 360w,
                        {{ media | image_url: width: 520 }} 520w,
                        {{ media | image_url: width: 720 }} 720w,
                        {{ media | image_url: width: 900 }} 900w
                      "
                      sizes="(max-width: 749px) {{ section.settings.card_width_mobile }}px, {{ section.settings.card_width_desktop }}px"
                      width="{{ media.width }}"
                      height="{{ media.height }}"
                      alt="{{ name | escape }}"
                      loading="lazy"
                      decoding="async"
                    >
                  {% else %}
                    <div class="fulva-buzz__slide-placeholder" aria-hidden="true"></div>
                  {% endif %}

                  {% if section.settings.show_play_icon and instagram_link == blank %}
                    <div class="fulva-buzz__slide-play" aria-hidden="true">
                      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M9 7.5v9l8-4.5-8-4.5z"></path>
                      </svg>
                    </div>
                  {% endif %}

                  {% if section.settings.show_metric %}
                    <div class="fulva-buzz__slide-views">{{ views | escape }}</div>
                  {% endif %}

                  {% if section.settings.show_likes %}
                    <div class="fulva-buzz__slide-likes" aria-label="Likes">
                      <span aria-hidden="true">♥</span>
                      <span>{{ likes | escape }}</span>
                    </div>
                  {% endif %}
                </div>
            {% if primary_link != blank %}
              </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_arrows %}
        <button class="fulva-buzz__carousel-arrow fulva-buzz__carousel-arrow--next" type="button" aria-label="Next" data-fb-next>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      {% endif %}
    </div>

  </div>
</section>


<script>
  (() => {
    const root = document.querySelector('.fulva-buzz--{{ section.id }}');
    if (!root) return;

    const prevBtn = root.querySelector('[data-fb-prev]');
    const nextBtn = root.querySelector('[data-fb-next]');
    const stage = root.querySelector('[data-fb-stage]');
    const slides = Array.from(root.querySelectorAll('[data-fb-slide]'));
    const profiles = Array.from(root.querySelectorAll('[data-fb-profile]'));
    const dots = Array.from(root.querySelectorAll('[data-fb-dot]'));
    if (!stage || slides.length === 0) return;

    const n = slides.length;
    let active = 0;

    const setActive = (idx) => {
      active = ((idx % n) + n) % n;

      const half = Math.floor(n / 2);
      slides.forEach((el, i) => {
        const raw = i - active;
        const wrapped = ((raw + n + half) % n) - half;
        el.classList.remove('is-active', 'is-prev', 'is-next', 'is-far-prev', 'is-far-next');

        if (wrapped === 0) el.classList.add('is-active');
        if (wrapped === -1) el.classList.add('is-prev');
        if (wrapped === 1) el.classList.add('is-next');
        if (wrapped === -2) el.classList.add('is-far-prev');
        if (wrapped === 2) el.classList.add('is-far-next');

        el.setAttribute('aria-hidden', wrapped === 0 ? 'false' : 'true');
      });

      profiles.forEach((p, i) => {
        p.classList.toggle('is-active', i === active);
      });

      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === active);
      });
    };

    const next = () => setActive(active + 1);
    const prev = () => setActive(active - 1);

    if (nextBtn) nextBtn.addEventListener('click', next);
    if (prevBtn) prevBtn.addEventListener('click', prev);

    profiles.forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.getAttribute('data-index') || '0', 10);
        setActive(idx);
      });
    });

    let startX = 0;
    let startY = 0;
    let tracking = false;

    stage.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'touch') return;
      tracking = true;
      startX = e.clientX;
      startY = e.clientY;
    }, { passive: true });

    stage.addEventListener('pointerup', (e) => {
      if (!tracking) return;
      tracking = false;
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;
      if (Math.abs(dx) < 42 || Math.abs(dx) < Math.abs(dy)) return;
      if (dx < 0) next();
      else prev();
    }, { passive: true });

    setActive(0);
  })();
</script>

{% schema %}
{
  "name": "Fulva buzz",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "What they’re saying" },


    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Loved by Celebs" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "They’re talking about <em>Fulva</em>" },
    { "type": "checkbox", "id": "show_subtitle", "label": "Show subtitle", "default": true },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Filmmakers, athletes, and influencers who fell for Calicut’s finest." },

    { "type": "header", "content": "CTA" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA", "default": false },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View all" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },

    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "show_arrows", "label": "Show navigation arrows (Desktop)", "default": true },
    { "type": "checkbox", "id": "show_play_icon", "label": "Show play icon on media", "default": true },
    { "type": "checkbox", "id": "show_profiles", "label": "Show profile strip", "default": true },
    { "type": "checkbox", "id": "show_likes", "label": "Show likes", "default": true },
    { "type": "checkbox", "id": "show_progress", "label": "Show progress indicators", "default": true },
    { "type": "range", "id": "max_width", "label": "Max width (0 = full width)", "min": 0, "max": 1800, "step": 20, "default": 0 },
    { "type": "range", "id": "padding_x_desktop", "label": "Padding X desktop (px)", "min": 0, "max": 90, "step": 2, "default": 64 },
    { "type": "range", "id": "padding_y_desktop", "label": "Padding Y desktop (px)", "min": 0, "max": 90, "step": 2, "default": 34 },
    { "type": "range", "id": "padding_x_mobile", "label": "Padding X mobile (px)", "min": 0, "max": 30, "step": 1, "default": 16 },
    { "type": "range", "id": "padding_y_mobile", "label": "Padding Y mobile (px)", "min": 0, "max": 60, "step": 1, "default": 18 },
    { "type": "range", "id": "gap", "label": "Card gap (px)", "min": 10, "max": 32, "step": 1, "default": 14 },
    { "type": "range", "id": "radius", "label": "Card radius (px)", "min": 0, "max": 28, "step": 1, "default": 18 },
    { "type": "range", "id": "media_radius", "label": "Media bottom radius (px)", "min": 0, "max": 28, "step": 1, "default": 18 },

    { "type": "header", "content": "Card sizes" },
    { "type": "range", "id": "card_width_desktop", "label": "Active card width desktop (px)", "min": 240, "max": 440, "step": 2, "default": 340 },
    { "type": "range", "id": "card_width_mobile", "label": "Active card width mobile (px)", "min": 200, "max": 340, "step": 2, "default": 260 },
    { "type": "range", "id": "stage_height_desktop", "label": "Carousel height desktop (px)", "min": 360, "max": 720, "step": 10, "default": 540 },
    { "type": "range", "id": "stage_height_mobile", "label": "Carousel height mobile (px)", "min": 320, "max": 680, "step": 10, "default": 500 },
    { "type": "range", "id": "slide_offset_desktop", "label": "Slide offset desktop (px)", "min": 120, "max": 260, "step": 2, "default": 180 },
    { "type": "range", "id": "slide_offset_mobile", "label": "Slide offset mobile (px)", "min": 90, "max": 200, "step": 2, "default": 140 },
    { "type": "range", "id": "mid_scale", "label": "Side scale (%)", "min": 60, "max": 95, "step": 1, "default": 86 },
    { "type": "range", "id": "far_scale", "label": "Far scale (%)", "min": 50, "max": 90, "step": 1, "default": 72 },
    { "type": "range", "id": "profile_size", "label": "Profile size (px)", "min": 46, "max": 86, "step": 2, "default": 62 },
    {
      "type": "select",
      "id": "card_aspect_ratio",
      "label": "Media aspect ratio",
      "default": "0.5625",
      "options": [
        { "value": "0.5625", "label": "9:16 (Reel)" },
        { "value": "0.6667", "label": "2:3 (Portrait)" },
        { "value": "0.75", "label": "3:4 (Portrait)" },
        { "value": "1", "label": "1:1 (Square)" }
      ]
    },

    { "type": "header", "content": "Content visibility" },
    { "type": "checkbox", "id": "show_badge", "label": "Show badge (unused)", "default": false },
    { "type": "checkbox", "id": "show_metric", "label": "Show metric pill", "default": true },
    { "type": "checkbox", "id": "show_title", "label": "Show role/title (profile strip)", "default": true },
    { "type": "checkbox", "id": "show_quote", "label": "Show quote (unused)", "default": false },
    { "type": "checkbox", "id": "show_handle", "label": "Show handle (unused)", "default": false },
    { "type": "checkbox", "id": "show_stars", "label": "Show stars (unused)", "default": false },

    { "type": "header", "content": "Colors" },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background style",
      "default": "radial",
      "options": [
        { "value": "radial", "label": "Radial (vignette)" },
        { "value": "linear", "label": "Linear" }
      ]
    },
    { "type": "checkbox", "id": "use_exact_palette", "label": "Lock exact screenshot colors", "default": true },
    { "type": "color", "id": "background", "label": "Background (top)", "default": "#0C6A20" },
    { "type": "color", "id": "background_2", "label": "Background (mid)", "default": "#064414" },
    { "type": "color", "id": "background_3", "label": "Background (edge)", "default": "#031A08" },
    { "type": "color", "id": "glow_1", "label": "Glow 1", "default": "#1C9A38" },
    { "type": "color", "id": "glow_2", "label": "Glow 2", "default": "#0B5F1D" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#FFFFFF" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#D4E3D7" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#F4C026" },
    { "type": "color", "id": "title_highlight_color", "label": "Title highlight color", "default": "#F4C026" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#FFFFFF" },
    { "type": "range", "id": "border_opacity", "label": "Section border opacity (%)", "min": 0, "max": 30, "step": 1, "default": 8 },
    { "type": "color", "id": "card_background", "label": "Card background (unused)", "default": "#FFFFFF" },
    { "type": "color", "id": "card_border_color", "label": "Card border color (unused)", "default": "#000000" },
    { "type": "range", "id": "card_border_opacity", "label": "Card border opacity (%)", "min": 0, "max": 30, "step": 1, "default": 8 },
    { "type": "color", "id": "shadow_color", "label": "Shadow color", "default": "#000000" },
    { "type": "range", "id": "shadow_opacity", "label": "Shadow opacity (%)", "min": 0, "max": 30, "step": 1, "default": 12 },

    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Hide on desktop", "default": false }
  ],
  "blocks": [
    {
      "type": "mention",
      "name": "Mention",
      "settings": [
        { "type": "video", "id": "video", "label": "Video (Reel)" },
        { "type": "text", "id": "instagram_link", "label": "Instagram Link (Reel/Post)" },
        { "type": "image_picker", "id": "media", "label": "Fallback image (if no video/link)" },
        { "type": "url", "id": "link", "label": "Link (optional)" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar (optional)" },
        { "type": "text", "id": "name", "label": "Name", "default": "Influencer Name" },
        { "type": "text", "id": "title", "label": "Role/title", "default": "INFLUENCER" },
        { "type": "text", "id": "handle", "label": "Handle", "default": "@fulva.in" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Trending" },
        { "type": "text", "id": "metric", "label": "Views", "default": "2.4M" },
        { "type": "text", "id": "like_text", "label": "Likes", "default": "84K" },
        { "type": "text", "id": "quote", "label": "Quote (unused)", "default": "Loved the taste and the giftable packaging." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fulva buzz",
      "blocks": [
        { "type": "mention" },
        { "type": "mention" },
        { "type": "mention" },
        { "type": "mention" }
      ]
    }
  ]
}
{% endschema %}

