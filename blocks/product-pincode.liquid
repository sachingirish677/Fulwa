<style>
  .product-pincode-{{ block.id }} {
    font-family: var(--font-body--family);
  }
  .product-pincode-{{ block.id }} .pincode-input-row {
    display: flex;
    align-items: center;
    background: #F9F9F9;
    border: 1px solid #E5E5E5;
    border-radius: 8px;
    padding: 4px 4px 4px 14px;
    gap: 8px;
    transition: border-color 0.2s ease;
  }
  .product-pincode-{{ block.id }} .pincode-input-row:focus-within {
    border-color: {{ block.settings.accent_color }};
  }
  .product-pincode-{{ block.id }} .pincode-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    color: #999;
  }
  .product-pincode-{{ block.id }} .pincode-icon svg {
    width: 100%;
    height: 100%;
  }
  .product-pincode-{{ block.id }} .pincode-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 13px;
    font-family: inherit;
    color: #333;
    outline: none;
    padding: 8px 0;
    min-width: 0;
  }
  .product-pincode-{{ block.id }} .pincode-input::placeholder {
    color: #AAAAAA;
  }
  .product-pincode-{{ block.id }} .pincode-btn {
    flex-shrink: 0;
    padding: 8px 20px;
    border: 1.5px solid {{ block.settings.accent_color }};
    border-radius: 6px;
    background: transparent;
    color: {{ block.settings.accent_color }};
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }
  .product-pincode-{{ block.id }} .pincode-btn:hover {
    background: {{ block.settings.accent_color }};
    color: #FFFFFF;
  }
  .product-pincode-{{ block.id }} .pincode-delivery {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    font-size: 13px;
    font-weight: 600;
    color: #333;
  }
  .product-pincode-{{ block.id }} .pincode-delivery-icon {
    width: 18px;
    height: 18px;
    color: {{ block.settings.accent_color }};
    flex-shrink: 0;
  }
  .product-pincode-{{ block.id }} .pincode-delivery-icon svg {
    width: 100%;
    height: 100%;
  }
</style>

<div class="product-pincode-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="pincode-input-row">
    <span class="pincode-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
    </span>
    <input class="pincode-input" type="text" placeholder="{{ block.settings.placeholder }}" maxlength="6" inputmode="numeric" pattern="[0-9]*">
    <button class="pincode-btn" type="button">{{ block.settings.button_text }}</button>
  </div>

  <div class="pincode-delivery">
    <span class="pincode-delivery-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="3" width="15" height="13" rx="1"/>
        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>
        <circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
    </span>
    <span>{{ block.settings.delivery_text }}</span>
  </div>
</div>

{% schema %}
{
  "name": "Product Pincode",
  "settings": [
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder Text",
      "default": "Enter your pincode to check estimated delivery date"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Check"
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "Delivery Text",
      "default": "Get it by Tue, Jun 23"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#387B45"
    }
  ],
  "presets": [
    { "name": "Product Pincode" }
  ]
}
{% endschema %}
