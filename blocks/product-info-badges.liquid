<style>
  .product-info-badges-{{ block.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-family: var(--font-body--family);
  }
  .product-info-badges-{{ block.id }} .info-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: {{ block.settings.badge_bg }};
    border: 1px solid {{ block.settings.badge_border }};
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    color: {{ block.settings.badge_text_color }};
    white-space: nowrap;
  }
  .product-info-badges-{{ block.id }} .info-badge__icon {
    width: 14px;
    height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .product-info-badges-{{ block.id }} .info-badge__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>

<div class="product-info-badges-{{ block.id }}" {{ block.shopify_attributes }}>
  {%- if block.settings.badge_1_text != blank -%}
    <span class="info-badge">
      {%- if block.settings.badge_1_icon != blank -%}
        <span class="info-badge__icon">
          <img src="{{ block.settings.badge_1_icon | image_url: width: 28 }}" alt="" loading="lazy">
        </span>
      {%- endif -%}
      {{ block.settings.badge_1_text }}
    </span>
  {%- endif -%}

  {%- if block.settings.badge_2_text != blank -%}
    <span class="info-badge">
      {%- if block.settings.badge_2_icon != blank -%}
        <span class="info-badge__icon">
          <img src="{{ block.settings.badge_2_icon | image_url: width: 28 }}" alt="" loading="lazy">
        </span>
      {%- endif -%}
      {{ block.settings.badge_2_text }}
    </span>
  {%- endif -%}

  {%- if block.settings.badge_3_text != blank -%}
    <span class="info-badge">
      {%- if block.settings.badge_3_icon != blank -%}
        <span class="info-badge__icon">
          <img src="{{ block.settings.badge_3_icon | image_url: width: 28 }}" alt="" loading="lazy">
        </span>
      {%- endif -%}
      {{ block.settings.badge_3_text }}
    </span>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Product Info Badges",
  "settings": [
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge Background",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "badge_border",
      "label": "Badge Border",
      "default": "#E8E8E8"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "image_picker",
      "id": "badge_1_icon",
      "label": "Badge 1 Icon"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1 Text",
      "default": "30 days shelf life"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "image_picker",
      "id": "badge_2_icon",
      "label": "Badge 2 Icon"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2 Text",
      "default": "200g"
    },
    {
      "type": "header",
      "content": "Badge 3"
    },
    {
      "type": "image_picker",
      "id": "badge_3_icon",
      "label": "Badge 3 Icon"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3 Text"
    }
  ],
  "presets": [
    { "name": "Product Info Badges" }
  ]
}
{% endschema %}
