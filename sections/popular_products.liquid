{% liquid
  assign section_products = section.blocks | where: 'type', 'product'
  assign border_alpha = section.settings.border_opacity | times: 0.01
  assign card_border_alpha = section.settings.card_border_opacity | times: 0.01
  assign shadow_alpha = section.settings.shadow_opacity | times: 0.01
%}

<section
  class="fulva-popular fulva-popular--{{ section.id }}{% if section.settings.hide_on_mobile %} fulva-popular--hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} fulva-popular--hide-desktop{% endif %}"
  aria-label="{{ section.settings.aria_label | escape }}"
  style="
    --fp-bg: {{ section.settings.background }};
    --fp-text: {{ section.settings.text_color }};
    --fp-muted: {{ section.settings.muted_text_color }};
    --fp-accent: {{ section.settings.accent_color }};
    --fp-title-accent: {{ section.settings.title_accent_color }};
    --fp-badge-bg: {{ section.settings.badge_bg_color }};
    --fp-green: {{ section.settings.primary_green }};
    --fp-green-hover: {{ section.settings.primary_green_hover }};
    --fp-border: {{ section.settings.border_color | color_modify: 'alpha', border_alpha }};
    --fp-card-border: {{ section.settings.card_border_color | color_modify: 'alpha', card_border_alpha }};
    --fp-shadow: {{ section.settings.shadow_color | color_modify: 'alpha', shadow_alpha }};
    --fp-max: {% if section.settings.max_width > 0 %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
    --fp-px: {{ section.settings.padding_x_desktop }}px;
    --fp-py: {{ section.settings.padding_y_desktop }}px;
    --fp-px-m: {{ section.settings.padding_x_mobile }}px;
    --fp-py-m: {{ section.settings.padding_y_mobile }}px;
    --fp-gap: {{ section.settings.gap }}px;
    --fp-radius: {{ section.settings.card_radius }}px;
    --fp-img-h: {{ section.settings.image_height }}px;
    --fp-card-w: {{ section.settings.card_width_desktop }}px;
    --fp-card-w-m: {{ section.settings.card_width_mobile }}px;
  "
>
  <div class="fulva-popular__inner">
    <div class="fulva-popular__head">
      <div class="fulva-popular__head-left">
        {% if section.settings.eyebrow != blank %}
          <div class="fulva-popular__eyebrow">{{ section.settings.eyebrow | escape }}</div>
        {% endif %}
        {% if section.settings.title_before != blank or section.settings.title_emphasis != blank or section.settings.title_after != blank %}
          <h2 class="fulva-popular__title">
            {% if section.settings.title_before != blank %}{{ section.settings.title_before }}{% endif %}
            {% if section.settings.title_emphasis != blank %}<em>{{ section.settings.title_emphasis }}</em>{% endif %}
            {% if section.settings.title_after != blank %}{{ section.settings.title_after }}{% endif %}
          </h2>
        {% endif %}
      </div>

      {% if section.settings.show_arrows %}
        <div class="fulva-popular__nav" aria-label="Carousel navigation">
          <button class="fulva-popular__arrow is-prev" type="button" aria-label="Previous" data-fp-prev>
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M14.7 5.3a1 1 0 0 1 0 1.4L9.4 12l5.3 5.3a1 1 0 1 1-1.4 1.4l-6-6a1 1 0 0 1 0-1.4l6-6a1 1 0 0 1 1.4 0z"></path>
            </svg>
          </button>
          <button class="fulva-popular__arrow is-next" type="button" aria-label="Next" data-fp-next>
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M9.3 18.7a1 1 0 0 1 0-1.4L14.6 12 9.3 6.7a1 1 0 1 1 1.4-1.4l6 6a1 1 0 0 1 0 1.4l-6 6a1 1 0 0 1-1.4 0z"></path>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>

    <div
      class="fulva-popular__track fulva-popular__track--m-{{ section.settings.mobile_layout }}"
      role="list"
      aria-label="{{ section.settings.aria_label | escape }}"
      data-fp-track
    >
      {% for block in section_products %}
        {% liquid
          assign product = block.settings.product
          assign variant = nil
          if product != blank
            assign variant = product.selected_or_first_available_variant
          endif

          assign display_image = block.settings.custom_image | default: product.featured_image

          assign show_custom_badge = block.settings.show_custom_badge
          assign badge_text = block.settings.badge_text

          assign show_percent_badge = false
          assign percent_off = 0
          if product != blank and variant != blank and variant.compare_at_price > variant.price
            assign diff = variant.compare_at_price | minus: variant.price
            assign percent_off = diff | times: 100.0 | divided_by: variant.compare_at_price | round
            assign show_percent_badge = true
          endif
        %}

        <div class="fulva-popular__card" role="listitem" {{ block.shopify_attributes }}>
          <div class="fulva-popular__media">
            {% if show_custom_badge and badge_text != blank %}
              <div class="fulva-popular__badge">{{ badge_text | escape }}</div>
            {% elsif show_percent_badge %}
              <div class="fulva-popular__badge">-{{ percent_off }}%</div>
            {% endif %}

            {% if display_image != blank %}
              <img
                class="fulva-popular__img"
                src="{{ display_image | image_url: width: 900 }}"
                srcset="
                  {{ display_image | image_url: width: 360 }} 360w,
                  {{ display_image | image_url: width: 540 }} 540w,
                  {{ display_image | image_url: width: 720 }} 720w,
                  {{ display_image | image_url: width: 900 }} 900w
                "
                sizes="(max-width: 749px) {{ section.settings.card_width_mobile }}px, 220px"
                width="{{ display_image.width }}"
                height="{{ display_image.height }}"
                alt="{{ display_image.alt | default: product.title | escape }}"
                loading="lazy"
                decoding="async"
              >
            {% else %}
              <div class="fulva-popular__ph" aria-hidden="true">✦</div>
            {% endif %}
          </div>

          <div class="fulva-popular__body">
            <div class="fulva-popular__name">
              {% if product != blank %}
                {{ product.title | escape }}
              {% else %}
                {{ block.settings.fallback_title | escape }}
              {% endif %}
            </div>

            {% if block.settings.subtitle != blank %}
              <div class="fulva-popular__subtitle">{{ block.settings.subtitle | escape }}</div>
            {% endif %}

            <div class="fulva-popular__footer">
              <div class="fulva-popular__prices">
                {% if variant != blank %}
                  <span class="fulva-popular__price">{{ variant.price | money }}</span>
                  {% if variant.compare_at_price > variant.price %}
                    <span class="fulva-popular__compare">{{ variant.compare_at_price | money }}</span>
                  {% endif %}
                {% else %}
                  <span class="fulva-popular__price">{{ section.settings.fallback_price | escape }}</span>
                {% endif %}
              </div>

              {% if product != blank and variant != blank %}
                {% form 'product', product, class: 'fulva-popular__form' %}
                  <input type="hidden" name="id" value="{{ variant.id }}">
                  <button class="fulva-popular__cart" type="submit"{% unless variant.available %} disabled{% endunless %}>
                    <span class="fulva-popular__plus">+</span>
                    <span>{{ section.settings.cart_label | escape }}</span>
                  </button>
                {% endform %}
              {% else %}
                <div class="fulva-popular__cart is-disabled">
                  <span class="fulva-popular__plus">+</span>
                  <span>{{ section.settings.cart_label | escape }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.view_all_label != blank %}
      <div class="fulva-popular__viewall">
        <a href="{{ section.settings.view_all_collection.url | default: '/collections/all' }}">{{ section.settings.view_all_label | escape }}</a>
      </div>
    {% endif %}
  </div>
</section>

{{ 'popular-products.css' | asset_url | stylesheet_tag }}

<script>
  (() => {
    const root = document.querySelector('.fulva-popular--{{ section.id }}');
    if (!root) return;
    const track = root.querySelector('[data-fp-track]');
    const prevBtn = root.querySelector('[data-fp-prev]');
    const nextBtn = root.querySelector('[data-fp-next]');
    if (!track) return;

    const getScrollAmount = () => {
      const card = track.querySelector('.fulva-popular__card');
      if (!card) return 320;
      const gap = parseInt(getComputedStyle(track).gap) || 0;
      return card.offsetWidth + gap;
    };

    const updateArrows = () => {
      if (!prevBtn || !nextBtn) return;
      prevBtn.disabled = track.scrollLeft <= 10;
      const maxScroll = track.scrollWidth - track.clientWidth;
      nextBtn.disabled = track.scrollLeft >= maxScroll - 10;
    };

    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => track.scrollBy({ left: -getScrollAmount() * 2, behavior: 'smooth' }));
      nextBtn.addEventListener('click', () => track.scrollBy({ left: getScrollAmount() * 2, behavior: 'smooth' }));
      track.addEventListener('scroll', updateArrows, { passive: true });
      window.addEventListener('resize', updateArrows);
      setTimeout(updateArrows, 100);
    }

    // Mouse drag scroll (desktop)
    let isDown = false;
    let startX = 0;
    let startScrollLeft = 0;
    let dragged = false;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      dragged = false;
      startX = e.pageX - track.offsetLeft;
      startScrollLeft = track.scrollLeft;
      track.classList.add('is-dragging');
      track.style.scrollSnapType = 'none';
    });

    const endDrag = () => {
      if (!isDown) return;
      isDown = false;
      track.classList.remove('is-dragging');
      track.style.scrollSnapType = '';
      setTimeout(() => {
        dragged = false;
      }, 0);
    };

    track.addEventListener('mouseleave', endDrag);
    track.addEventListener('mouseup', endDrag);

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 2;
      if (Math.abs(walk) > 10) dragged = true;
      track.scrollLeft = startScrollLeft - walk;
    });

    track.addEventListener(
      'click',
      (e) => {
        if (!dragged) return;
        e.preventDefault();
        e.stopPropagation();
      },
      true
    );
  })();
</script>

{% schema %}
{
  "name": "Fulva popular products",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "Most popular products" },

    { "type": "header", "content": "Text" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Top sellers" },
    { "type": "text", "id": "title_before", "label": "Title (before)", "default": "Most" },
    { "type": "text", "id": "title_emphasis", "label": "Title (italic)", "default": "Popular" },
    { "type": "text", "id": "title_after", "label": "Title (after)", "default": "Products" },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout_mode", "label": "Desktop layout", "default": "grid", "options": [
      { "value": "grid", "label": "Grid" },
      { "value": "carousel", "label": "Carousel (scroll)" }
    ]},
    { "type": "select", "id": "mobile_layout", "label": "Mobile layout", "default": "swipe", "options": [
      { "value": "grid", "label": "2-column grid" },
      { "value": "swipe", "label": "Swipe carousel" }
    ]},
    { "type": "checkbox", "id": "show_arrows", "label": "Show navigation arrows (desktop)", "default": true },
    { "type": "range", "id": "max_width", "label": "Max width (0 = full width)", "min": 0, "max": 1800, "step": 20, "default": 0 },
    { "type": "range", "id": "padding_x_desktop", "label": "Padding X desktop (px)", "min": 0, "max": 100, "step": 2, "default": 64 },
    { "type": "range", "id": "padding_y_desktop", "label": "Padding Y desktop (px)", "min": 0, "max": 120, "step": 2, "default": 52 },
    { "type": "range", "id": "padding_x_mobile", "label": "Padding X mobile (px)", "min": 0, "max": 30, "step": 1, "default": 16 },
    { "type": "range", "id": "padding_y_mobile", "label": "Padding Y mobile (px)", "min": 0, "max": 60, "step": 1, "default": 24 },
    { "type": "range", "id": "gap", "label": "Card gap (px)", "min": 8, "max": 24, "step": 1, "default": 14 },
    { "type": "range", "id": "card_radius", "label": "Image radius (px)", "min": 0, "max": 24, "step": 1, "default": 15 },
    { "type": "range", "id": "image_height", "label": "Image height (px)", "min": 140, "max": 320, "step": 2, "default": 200 },
    { "type": "range", "id": "card_width_desktop", "label": "Carousel card width desktop (px)", "min": 200, "max": 360, "step": 2, "default": 248 },
    { "type": "range", "id": "card_width_mobile", "label": "Carousel card width mobile (px)", "min": 160, "max": 300, "step": 2, "default": 210 },

    { "type": "header", "content": "Links" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All Products ➔" },
    { "type": "collection", "id": "view_all_collection", "label": "View all collection" },
    { "type": "text", "id": "cart_label", "label": "Cart label", "default": "Cart" },
    { "type": "text", "id": "fallback_price", "label": "Fallback price", "default": "₹1,113" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background", "label": "Background", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#000000" },
    { "type": "color", "id": "title_accent_color", "label": "Title accent (italic)", "default": "#000000" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#8A8A8A" },
    { "type": "color", "id": "accent_color", "label": "Eyebrow accent", "default": "#D4A843" },
    { "type": "color", "id": "badge_bg_color", "label": "Badge background", "default": "#1B5E2F" },
    { "type": "color", "id": "primary_green", "label": "Primary green", "default": "#1B5E2F" },
    { "type": "color", "id": "primary_green_hover", "label": "Primary green hover", "default": "#237A3B" },
    { "type": "color", "id": "border_color", "label": "Top border", "default": "#000000" },
    { "type": "range", "id": "border_opacity", "label": "Top border opacity (%)", "min": 0, "max": 30, "step": 1, "default": 6 },
    { "type": "color", "id": "card_border_color", "label": "Card border (optional)", "default": "#000000" },
    { "type": "range", "id": "card_border_opacity", "label": "Card border opacity (%)", "min": 0, "max": 20, "step": 1, "default": 0 },
    { "type": "color", "id": "shadow_color", "label": "Shadow color", "default": "#000000" },
    { "type": "range", "id": "shadow_opacity", "label": "Shadow opacity (%)", "min": 0, "max": 30, "step": 1, "default": 10 },

    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Hide on desktop", "default": false }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 20,
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "custom_image", "label": "Custom Image Override", "info": "If added, this image will display instead of the product's default image." },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Assorted · 120g" },
        { "type": "checkbox", "id": "show_custom_badge", "label": "Show custom badge", "default": false },
        { "type": "text", "id": "badge_text", "label": "Badge text", "default": "~50%" },
        { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "Product name" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fulva popular products",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
