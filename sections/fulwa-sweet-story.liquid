{{ 'fulwa-sweet-story.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .fss-section--{{ section.id }} {
    --fss-pt: {{ section.settings.padding_top }}px;
    --fss-pb: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  class="fss-section fss-section--{{ section.id }}"
  style="background: linear-gradient(to bottom, {{ section.settings.grad_start | default: '#F4C026' }}, {{ section.settings.grad_end | default: '#ffffff' }}); padding-top: var(--fss-pt, 48px); padding-bottom: var(--fss-pb, 44px);"
>
  <div class="fss-hero">

    {%- comment -%} Decorative floating images {%- endcomment -%}
    {%- if section.settings.deco_left != blank -%}
      <div class="fss-hero__deco-left">
        {{ section.settings.deco_left | image_url: width: 400 | image_tag: loading: 'lazy' }}
      </div>
    {%- endif -%}

    {%- if section.settings.deco_right != blank -%}
      <div class="fss-hero__deco-right">
        {{ section.settings.deco_right | image_url: width: 300 | image_tag: loading: 'lazy' }}
      </div>
    {%- endif -%}

    {%- comment -%} Product Image {%- endcomment -%}
    {%- if section.settings.product_image != blank -%}
      <div class="fss-hero__product-image">
        {{ section.settings.product_image | image_url: width: 800 | image_tag: loading: 'eager' }}
      </div>
    {%- endif -%}

    {%- comment -%} Tagline {%- endcomment -%}
    {%- if section.settings.tagline != blank -%}
      <div class="fss-hero__tagline">
        {{ section.settings.tagline }}
      </div>
    {%- endif -%}

    {%- comment -%} Heading {%- endcomment -%}
    <h2 class="fss-hero__heading">
      {{ section.settings.heading }}
      {%- if section.settings.heading_highlight != blank -%}
        <span class="fss-hero__heading-highlight" style="color: {{ section.settings.heading_highlight_color }};">
          {{ section.settings.heading_highlight }}
        </span>
      {%- endif -%}
    </h2>

    {%- comment -%} Description {%- endcomment -%}
    {%- if section.settings.description != blank -%}
      <p class="fss-hero__description">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- comment -%} Trust Badges {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="fss-hero__badges">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_badge' -%}
            <div class="fss-badge" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="fss-badge__icon">
                  {{ block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy' }}
                </div>
              {%- endif -%}
              <div class="fss-badge__text">
                {%- if block.settings.highlight != blank -%}
                  <span class="fss-badge__highlight">{{ block.settings.highlight }}</span>
                {%- endif -%}
                {{ block.settings.label }}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Sweet Story Header",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "grad_start",
      "label": "Gradient Start (Top)",
      "default": "#F4C026"
    },
    {
      "type": "color",
      "id": "grad_end",
      "label": "Gradient End (Bottom)",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image (Center)"
    },
    {
      "type": "image_picker",
      "id": "deco_left",
      "label": "Decorative Image (Left)",
      "info": "Floating accent image on the left side"
    },
    {
      "type": "image_picker",
      "id": "deco_right",
      "label": "Decorative Image (Right)",
      "info": "Floating accent image on the right side"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "THE LEGACY OF CALICUT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Sweet Story of"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight",
      "default": "Fulva"
    },
    {
      "type": "color",
      "id": "heading_highlight_color",
      "label": "Heading Highlight Color",
      "default": "#2E7D32"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "From Arab traders arriving at the shores of Calicut to Fulva sharing Kerala's regional taste worldwide — this is the journey of tradition, friendship, and authentic halwa."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 44
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Badge Icon"
        },
        {
          "type": "text",
          "id": "highlight",
          "label": "Highlight Text",
          "info": "Bold text like '50K+' (optional)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Badge Label",
          "default": "Badge Text"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Sweet Story Header",
      "blocks": [
        {
          "type": "trust_badge",
          "settings": {
            "label": "Approved"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "label": "Free Delivery"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "highlight": "50K+",
            "label": "Happy Customers"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "label": "Product of India"
          }
        }
      ]
    }
  ]
}
{% endschema %}
