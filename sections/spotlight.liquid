{{ 'spotlight.css' | asset_url | stylesheet_tag }}
{% liquid
  assign border_alpha = section.settings.border_opacity | times: 0.01
  assign card_border_alpha = section.settings.card_border_opacity | times: 0.01
  assign shadow_alpha = section.settings.shadow_opacity | times: 0.01
  assign blob_1_alpha = section.settings.blob_1_opacity | times: 0.01
  assign blob_2_alpha = section.settings.blob_2_opacity | times: 0.01
  assign radial_95 = section.settings.radial_color | color_modify: 'alpha', 0.95
  assign radial_60 = section.settings.radial_color | color_modify: 'alpha', 0.60
  assign radial_20 = section.settings.radial_color | color_modify: 'alpha', 0.20
  assign radial_0 = section.settings.radial_color | color_modify: 'alpha', 0
  assign accent_35 = section.settings.accent_color | color_modify: 'alpha', 0.35
  assign accent_30 = section.settings.accent_color | color_modify: 'alpha', 0.30
  assign accent_22 = section.settings.accent_color | color_modify: 'alpha', 0.22

  assign spotlight_products = section.blocks | where: 'type', 'product'
%}

<section
  class="fulva-spotlight fulva-spotlight--{{ section.id }}{% if section.settings.hide_on_mobile %} fulva-spotlight--hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} fulva-spotlight--hide-desktop{% endif %}"
  aria-label="{{ section.settings.aria_label | escape }}"
  style="
    --fs-bg: {{ section.settings.background }};
    --fs-decor-bg: {{ section.settings.decor_gradient }};
    --fs-radial: {{ section.settings.radial_color }};
    --fs-radial-60: {{ radial_60 }};
    --fs-radial-0: {{ radial_0 }};
    --fs-text: {{ section.settings.text_color }};
    --fs-muted: {{ section.settings.muted_text_color }};
    --fs-accent: {{ section.settings.accent_color }};
    --fs-accent-35: {{ accent_35 }};
    --fs-accent-30: {{ accent_30 }};
    --fs-accent-22: {{ accent_22 }};
    --fs-green: {{ section.settings.primary_green }};
    --fs-green-hover: {{ section.settings.primary_green_hover }};
    --fs-border: {{ section.settings.border_color | color_modify: 'alpha', border_alpha }};
    --fs-topline-1: {{ section.settings.topline_color_1 }};
    --fs-topline-2: {{ section.settings.topline_color_2 }};
    --fs-card-border: {{ section.settings.card_border_color | color_modify: 'alpha', card_border_alpha }};
    --fs-shadow: {{ section.settings.shadow_color | color_modify: 'alpha', shadow_alpha }};
    --fs-blob-1: {{ section.settings.blob_1_color | color_modify: 'alpha', blob_1_alpha }};
    --fs-blob-2: {{ section.settings.blob_2_color | color_modify: 'alpha', blob_2_alpha }};
    --fs-max: {% if section.settings.max_width > 0 %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
    --fs-px: {{ section.settings.padding_x_desktop }}px;
    --fs-py: {{ section.settings.padding_y_desktop }}px;
    --fs-px-m: {{ section.settings.padding_x_mobile }}px;
    --fs-py-m: {{ section.settings.padding_y_mobile }}px;
    --fs-gap: {{ section.settings.gap }}px;
    --fs-radius: {{ section.settings.card_radius }}px;
    --fs-img-h: {{ section.settings.image_height }}px;
    --fs-card-w: {{ section.settings.card_width_desktop }}px;
    --fs-card-w-m: {{ section.settings.card_width_mobile }}px;
  "
>
  <div class="fulva-spotlight__decor" aria-hidden="true">
    <span class="fulva-spotlight__line-left"></span>
    <span class="fulva-spotlight__line-right"></span>
  </div>

  <div class="fulva-spotlight__inner">
    <div class="fulva-spotlight__header">
      {% if section.settings.eyebrow != blank %}
        <div class="fulva-spotlight__eyebrow">{{ section.settings.eyebrow | escape }}</div>
      {% endif %}

      {% assign show_title_after = false %}
      {% if section.settings.show_title_after and section.settings.title_after != blank %}
        {% assign show_title_after = true %}
      {% endif %}

      {% if section.settings.title_before != blank or section.settings.title_emphasis != blank or show_title_after %}
        <h2 class="fulva-spotlight__title">
          {% if section.settings.title_before != blank %}{{ section.settings.title_before }}{% endif %}
          {% if section.settings.title_emphasis != blank %}<em>{{ section.settings.title_emphasis }}</em>{% endif %}
          {% if show_title_after %}{{ section.settings.title_after }}{% endif %}
        </h2>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <div class="fulva-spotlight__sub">{{ section.settings.subtitle }}</div>
      {% endif %}
    </div>

    <div class="fulva-spotlight__track-wrap">
      {% if section.settings.show_arrows %}
        <button class="fulva-spotlight__arrow is-prev" type="button" aria-label="Scroll left" data-fs-prev>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M14.7 5.3a1 1 0 0 1 0 1.4L9.4 12l5.3 5.3a1 1 0 1 1-1.4 1.4l-6-6a1 1 0 0 1 0-1.4l6-6a1 1 0 0 1 1.4 0z"></path>
          </svg>
        </button>
      {% endif %}

      <div
        class="fulva-spotlight__track{% if section.settings.desktop_layout == 'carousel' %} is-carousel{% endif %}{% if section.settings.mobile_layout == 'swipe' %} is-mobile-swipe{% endif %}"
        role="list"
        aria-label="{{ section.settings.aria_label | escape }}"
        data-fs-track
      >
        {% for block in spotlight_products %}
          {% liquid
            assign product = block.settings.product
            assign variant = nil
            if product != blank
              assign variant = product.selected_or_first_available_variant
            endif

            assign show_custom_badge = block.settings.show_custom_badge
            assign badge_text = block.settings.badge_text

            assign show_percent_badge = false
            assign percent_off = 0
            if product != blank and variant != blank and variant.compare_at_price > variant.price
              assign diff = variant.compare_at_price | minus: variant.price
              assign percent_off = diff | times: 100.0 | divided_by: variant.compare_at_price | round
              assign show_percent_badge = true
            endif
          %}

          <div class="fulva-spotlight__card" role="listitem" {{ block.shopify_attributes }}>
            <a href="{{ product.url | default: '#' }}" class="fulva-spotlight__media">
              {% if show_percent_badge %}
                <div class="fulva-spotlight__badge">-{{ percent_off }}%</div>
              {% elsif show_custom_badge and badge_text != blank %}
                <div class="fulva-spotlight__badge">{{ badge_text | escape }}</div>
              {% endif %}

              {% assign card_image = block.settings.custom_image | default: product.featured_image %}
              {% if card_image != blank %}
                <img
                  class="fulva-spotlight__img"
                  src="{{ card_image | image_url: width: 1200 }}"
                  srcset="
                    {{ card_image | image_url: width: 360 }} 360w,
                    {{ card_image | image_url: width: 540 }} 540w,
                    {{ card_image | image_url: width: 720 }} 720w,
                    {{ card_image | image_url: width: 900 }} 900w,
                    {{ card_image | image_url: width: 1200 }} 1200w
                  "
                  sizes="(max-width: 749px) {{ section.settings.card_width_mobile }}px, 360px"
                  width="{{ card_image.width }}"
                  height="{{ card_image.height }}"
                  alt="{{ card_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  decoding="async"
                >
              {% else %}
                <div class="fulva-spotlight__ph" aria-hidden="true">✦</div>
              {% endif %}
            </a>

            <div class="fulva-spotlight__body">
              <a href="{{ product.url | default: '#' }}" class="fulva-spotlight__name">
                {% if product != blank %}
                  {{ product.title | escape }}
                {% else %}
                  {{ block.settings.fallback_title | escape }}
                {% endif %}
              </a>

              {% if block.settings.subtitle != blank %}
                <div class="fulva-spotlight__subtitle">{{ block.settings.subtitle | escape }}</div>
              {% endif %}

              <div class="fulva-spotlight__footer">
                <div class="fulva-spotlight__prices">
                  {% if variant != blank %}
                    <span class="fulva-spotlight__price">{{ variant.price | money }}</span>
                    {% if variant.compare_at_price > variant.price %}
                      <span class="fulva-spotlight__compare">{{ variant.compare_at_price | money }}</span>
                    {% endif %}
                  {% else %}
                    <span class="fulva-spotlight__price">{{ section.settings.fallback_price | escape }}</span>
                  {% endif %}
                </div>

                {% if product != blank and variant != blank %}
                  {% form 'product', product, class: 'fulva-spotlight__form' %}
                    <input type="hidden" name="id" value="{{ variant.id }}">
                    <button class="fulva-spotlight__cart" type="submit"{% unless variant.available %} disabled{% endunless %}>
                      <span class="fulva-spotlight__plus">+</span>
                      <span>{{ section.settings.cart_label | escape }}</span>
                    </button>
                  {% endform %}
                {% else %}
                  <div class="fulva-spotlight__cart is-disabled">
                    <span class="fulva-spotlight__plus">+</span>
                    <span>{{ section.settings.cart_label | escape }}</span>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_arrows %}
        <button class="fulva-spotlight__arrow is-next" type="button" aria-label="Scroll right" data-fs-next>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M9.3 18.7a1 1 0 0 1 0-1.4L14.6 12 9.3 6.7a1 1 0 1 1 1.4-1.4l6 6a1 1 0 0 1 0 1.4l-6 6a1 1 0 0 1-1.4 0z"></path>
          </svg>
        </button>
      {% endif %}
    </div>
  </div>
</section>



<script>
  (() => {
    const root = document.querySelector('.fulva-spotlight--{{ section.id }}');
    if (!root) return;
    const track = root.querySelector('[data-fs-track]');
    const prevBtn = root.querySelector('[data-fs-prev]');
    const nextBtn = root.querySelector('[data-fs-next]');
    if (!track) return;

    const isCarousel = track.classList.contains('is-carousel');
    if (!isCarousel || !prevBtn || !nextBtn) return;

    const getScrollAmount = () => {
      const card = track.querySelector('.fulva-spotlight__card');
      if (!card) return 360;
      const gap = parseInt(getComputedStyle(track).gap) || 0;
      return card.offsetWidth + gap;
    };

    const updateArrows = () => {
      prevBtn.disabled = track.scrollLeft <= 10;
      const maxScroll = track.scrollWidth - track.clientWidth;
      nextBtn.disabled = track.scrollLeft >= maxScroll - 10;
    };

    prevBtn.addEventListener('click', () => track.scrollBy({ left: -getScrollAmount() * 2, behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => track.scrollBy({ left: getScrollAmount() * 2, behavior: 'smooth' }));
    track.addEventListener('scroll', updateArrows, { passive: true });
    window.addEventListener('resize', updateArrows);
    setTimeout(updateArrows, 100);

    // Mouse drag scroll (desktop)
    let isDown = false;
    let startX = 0;
    let startScrollLeft = 0;
    let dragged = false;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      dragged = false;
      startX = e.pageX - track.offsetLeft;
      startScrollLeft = track.scrollLeft;
      track.classList.add('is-dragging');
      track.style.scrollSnapType = 'none';
    });

    const endDrag = () => {
      if (!isDown) return;
      isDown = false;
      track.classList.remove('is-dragging');
      track.style.scrollSnapType = '';
      setTimeout(() => (dragged = false), 0);
    };

    track.addEventListener('mouseleave', endDrag);
    track.addEventListener('mouseup', endDrag);

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 2;
      if (Math.abs(walk) > 10) dragged = true;
      track.scrollLeft = startScrollLeft - walk;
    });

    track.addEventListener(
      'click',
      (e) => {
        if (!dragged) return;
        e.preventDefault();
        e.stopPropagation();
      },
      true
    );
  })();
</script>

{% schema %}
{
  "name": "Fulva spotlight",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "In the spotlight products" },

    { "type": "header", "content": "Text" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our finest" },
    { "type": "text", "id": "title_before", "label": "Title (before)", "default": "In the" },
    { "type": "text", "id": "title_emphasis", "label": "Title (italic)", "default": "Spotlight" },
    { "type": "checkbox", "id": "show_title_after", "label": "Show title after", "default": false },
    { "type": "text", "id": "title_after", "label": "Title (after)", "default": "Products" },
    { "type": "inline_richtext", "id": "subtitle", "label": "Subtitle", "default": "Hand-picked favorites crafted for gifting and sharing." },

    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "desktop_layout", "label": "Desktop layout", "default": "grid", "options": [
      { "value": "grid", "label": "3-column grid" },
      { "value": "carousel", "label": "Carousel (scroll)" }
    ]},
    { "type": "select", "id": "mobile_layout", "label": "Mobile layout", "default": "swipe", "options": [
      { "value": "grid", "label": "1-column grid" },
      { "value": "swipe", "label": "Swipe carousel" }
    ]},
    { "type": "checkbox", "id": "show_arrows", "label": "Show navigation arrows (desktop)", "default": false },
    { "type": "range", "id": "max_width", "label": "Max width (0 = full width)", "min": 0, "max": 1800, "step": 20, "default": 0 },
    { "type": "range", "id": "padding_x_desktop", "label": "Padding X desktop (px)", "min": 0, "max": 120, "step": 2, "default": 64 },
    { "type": "range", "id": "padding_y_desktop", "label": "Padding Y desktop (px)", "min": 0, "max": 120, "step": 2, "default": 56 },
    { "type": "range", "id": "padding_x_mobile", "label": "Padding X mobile (px)", "min": 0, "max": 30, "step": 1, "default": 16 },
    { "type": "range", "id": "padding_y_mobile", "label": "Padding Y mobile (px)", "min": 0, "max": 60, "step": 1, "default": 24 },
    { "type": "range", "id": "gap", "label": "Card gap (px)", "min": 8, "max": 26, "step": 1, "default": 14 },
    { "type": "range", "id": "card_radius", "label": "Image radius (px)", "min": 0, "max": 24, "step": 1, "default": 15 },
    { "type": "range", "id": "image_height", "label": "Image height (px)", "min": 180, "max": 380, "step": 2, "default": 270 },
    { "type": "range", "id": "card_width_desktop", "label": "Carousel card width desktop (px)", "min": 260, "max": 420, "step": 2, "default": 360 },
    { "type": "range", "id": "card_width_mobile", "label": "Carousel card width mobile (px)", "min": 200, "max": 340, "step": 2, "default": 280 },
    { "type": "text", "id": "cart_label", "label": "Cart label", "default": "Cart" },
    { "type": "text", "id": "fallback_price", "label": "Fallback price", "default": "₹1,113" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background", "label": "Background", "default": "#FFFFFF" },
    { "type": "color_background", "id": "decor_gradient", "label": "Background Gradient", "default": "linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(244,192,38,1) 50%, rgba(255,255,255,1) 100%)" },
    { "type": "color", "id": "radial_color", "label": "Radial highlight", "default": "#F4C026" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#000000" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text", "default": "#8A8A8A" },
    { "type": "color", "id": "accent_color", "label": "Eyebrow accent", "default": "#D4A843" },
    { "type": "color", "id": "primary_green", "label": "Primary green", "default": "#1B5E2F" },
    { "type": "color", "id": "primary_green_hover", "label": "Primary green hover", "default": "#237A3B" },
    { "type": "color", "id": "border_color", "label": "Top border base", "default": "#000000" },
    { "type": "range", "id": "border_opacity", "label": "Top border opacity (%)", "min": 0, "max": 30, "step": 1, "default": 6 },
    { "type": "color", "id": "topline_color_1", "label": "Top line color 1", "default": "#1B5E2F" },
    { "type": "color", "id": "topline_color_2", "label": "Top line color 2", "default": "#2AAE7F" },
    { "type": "color", "id": "card_border_color", "label": "Card border (optional)", "default": "#000000" },
    { "type": "range", "id": "card_border_opacity", "label": "Card border opacity (%)", "min": 0, "max": 20, "step": 1, "default": 0 },
    { "type": "color", "id": "shadow_color", "label": "Shadow color", "default": "#000000" },
    { "type": "range", "id": "shadow_opacity", "label": "Shadow opacity (%)", "min": 0, "max": 30, "step": 1, "default": 10 },
    { "type": "color", "id": "blob_1_color", "label": "Blob 1 color", "default": "#1B5E2F" },
    { "type": "range", "id": "blob_1_opacity", "label": "Blob 1 opacity (%)", "min": 0, "max": 30, "step": 1, "default": 12 },
    { "type": "color", "id": "blob_2_color", "label": "Blob 2 color", "default": "#D4A843" },
    { "type": "range", "id": "blob_2_opacity", "label": "Blob 2 opacity (%)", "min": 0, "max": 30, "step": 1, "default": 12 },

    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Hide on desktop", "default": false }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 12,
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "custom_image", "label": "Custom card image", "info": "Overrides product image if uploaded." },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Assorted · 120g" },
        { "type": "checkbox", "id": "show_custom_badge", "label": "Show custom badge", "default": false },
        { "type": "text", "id": "badge_text", "label": "Badge text", "default": "~50%" },
        { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "Product name" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fulva spotlight",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
