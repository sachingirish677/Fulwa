{{ 'featured-marquee.css' | asset_url | stylesheet_tag }}

<div class="featured-marquee" style="--fm-bg: {{ section.settings.bg_color }}; --fm-height: {{ section.settings.max_height }}px; --fm-speed: {{ section.settings.speed }}s;">
  {%- if section.blocks.size > 0 -%}
    {%- assign first_block = section.blocks.first -%}

    {%- comment -%} Mobile: first image centered above marquee {%- endcomment -%}
    <div class="fm-mobile-header">
      {%- assign mobile_first_image = first_block.settings.image_mobile | default: first_block.settings.image -%}
      {%- if mobile_first_image != blank -%}
        <img src="{{ mobile_first_image | img_url: 'master' }}" alt="{{ mobile_first_image.alt | escape }}" loading="lazy" class="fm-image">
      {%- else -%}
        <div class="fm-placeholder">Upload Logo</div>
      {%- endif -%}
    </div>

    {%- comment -%} Desktop: first image pinned to left, static {%- endcomment -%}
    <div class="fm-static">
      {%- assign desktop_first_image = first_block.settings.image | default: first_block.settings.image_mobile -%}
      {%- if desktop_first_image != blank -%}
        <img src="{{ desktop_first_image | img_url: 'master' }}" alt="{{ desktop_first_image.alt | escape }}" loading="lazy" class="fm-image">
      {%- else -%}
        <div class="fm-placeholder">Upload Logo</div>
      {%- endif -%}
      <span class="fm-separator"></span>
    </div>
  {%- endif -%}

  <div class="fm-track">
    {%- for i in (1..2) -%}
      <div class="fm-group" aria-hidden="{% if forloop.index == 2 %}true{% else %}false{% endif %}">
        {%- for block in section.blocks -%}
          {%- unless forloop.first -%}
            <div class="fm-item" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank or block.settings.image_mobile != blank -%}
                {%- assign default_image = block.settings.image | default: block.settings.image_mobile -%}
                <picture class="fm-image-picture">
                  {%- if block.settings.image_mobile != blank -%}
                    <source media="(max-width: 990px)" srcset="{{ block.settings.image_mobile | img_url: 'master' }}">
                  {%- endif -%}
                  {%- if block.settings.image != blank -%}
                    <source media="(min-width: 991px)" srcset="{{ block.settings.image | img_url: 'master' }}">
                  {%- endif -%}
                  <img src="{{ default_image | img_url: 'master' }}" alt="{{ default_image.alt | escape }}" loading="lazy" class="fm-image">
                </picture>
              {%- else -%}
                <div class="fm-placeholder">Upload Logo</div>
              {%- endif -%}
            </div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Marquee",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F2F7F2"
    },
    {
      "type": "range",
      "id": "max_height",
      "label": "Block Height",
      "min": 50,
      "max": 250,
      "step": 2,
      "default": 166,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation Speed (seconds)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Logo Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (Desktop)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Image (Mobile)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Marquee",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
