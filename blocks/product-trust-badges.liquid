<style>
  .product-trust-badges-{{ block.id }} {
    display: flex;
    flex-wrap: nowrap;
    gap: 8px;
    font-family: var(--font-body--family);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
  }
  .product-trust-badges-{{ block.id }}::-webkit-scrollbar {
    display: none;
  }
  .product-trust-badges-{{ block.id }} .trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-width: 86px;
    padding: 12px 10px;
    background: {{ block.settings.badge_bg }};
    border: 1px solid {{ block.settings.badge_border }};
    border-radius: 10px;
    text-align: center;
    flex-shrink: 0;
  }
  .product-trust-badges-{{ block.id }} .trust-badge__icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-trust-badges-{{ block.id }} .trust-badge__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .product-trust-badges-{{ block.id }} .trust-badge__text {
    font-size: 10px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    line-height: 1.3;
    max-width: 72px;
  }
</style>

<div class="product-trust-badges-{{ block.id }}" {{ block.shopify_attributes }}>
  {%- for i in (1..5) -%}
    {%- liquid
      case i
        when 1
          assign badge_icon = block.settings.badge_1_icon
          assign badge_text = block.settings.badge_1_text
        when 2
          assign badge_icon = block.settings.badge_2_icon
          assign badge_text = block.settings.badge_2_text
        when 3
          assign badge_icon = block.settings.badge_3_icon
          assign badge_text = block.settings.badge_3_text
        when 4
          assign badge_icon = block.settings.badge_4_icon
          assign badge_text = block.settings.badge_4_text
        when 5
          assign badge_icon = block.settings.badge_5_icon
          assign badge_text = block.settings.badge_5_text
      endcase
    -%}

    {%- if badge_text != blank -%}
      <div class="trust-badge">
        {%- if badge_icon != blank -%}
          <span class="trust-badge__icon">
            <img src="{{ badge_icon | image_url: width: 48 }}" alt="{{ badge_text }}" loading="lazy">
          </span>
        {%- endif -%}
        <span class="trust-badge__text">{{ badge_text }}</span>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Product Trust Badges",
  "settings": [
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge Background",
      "default": "#F9F9F9"
    },
    {
      "type": "color",
      "id": "badge_border",
      "label": "Badge Border",
      "default": "#EEEEEE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "image_picker",
      "id": "badge_1_icon",
      "label": "Icon 1"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Label 1",
      "default": "FSSAI Certified"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "image_picker",
      "id": "badge_2_icon",
      "label": "Icon 2"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Label 2",
      "default": "Approved"
    },
    {
      "type": "header",
      "content": "Badge 3"
    },
    {
      "type": "image_picker",
      "id": "badge_3_icon",
      "label": "Icon 3"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Label 3",
      "default": "Free Delivery"
    },
    {
      "type": "header",
      "content": "Badge 4"
    },
    {
      "type": "image_picker",
      "id": "badge_4_icon",
      "label": "Icon 4"
    },
    {
      "type": "text",
      "id": "badge_4_text",
      "label": "Label 4",
      "default": "Fast Shipping"
    },
    {
      "type": "header",
      "content": "Badge 5"
    },
    {
      "type": "image_picker",
      "id": "badge_5_icon",
      "label": "Icon 5"
    },
    {
      "type": "text",
      "id": "badge_5_text",
      "label": "Label 5",
      "default": "Product of India"
    }
  ],
  "presets": [
    { "name": "Product Trust Badges" }
  ]
}
{% endschema %}
