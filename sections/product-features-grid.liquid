{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .pf-container-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 16px;
  }

  .pf-top-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pf-top-left-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }

  .pf-top-right-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pf-bottom-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pf-bottom-item-{{ section.id }} {
    aspect-ratio: 16 / 10;
    width: 100%;
  }

  /* Protect text on left and right images by anchoring crop to the left edge */
  .pf-bottom-item-{{ section.id }}:nth-child(1) .pf-item img,
  .pf-bottom-item-{{ section.id }}:nth-child(3) .pf-item img {
    object-position: left center;
  }


  .pf-item {
    display: block;
    width: 100%;
    height: 100%;
  }

  .pf-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 8px; /* Optional subtle radius */
  }

  /* Desktop Flexbox Configuration */
  @media screen and (min-width: 750px) {
    .pf-container-{{ section.id }} {
      padding: 0 32px;
    }
    
    .pf-top-{{ section.id }} {
      flex-direction: row;
      align-items: stretch;
    }
    
    .pf-top-left-{{ section.id }} {
      flex: 2;
      min-width: 0;
    }
    
    .pf-top-left-{{ section.id }} .pf-item {
      height: 100%;
    }
    
    .pf-top-right-{{ section.id }} {
      flex: 1;
      min-width: 0;
    }

    .pf-top-right-{{ section.id }} .pf-item {
      flex: 1;
      height: 100%;
    }

    .pf-bottom-{{ section.id }} {
      flex-direction: row;
      align-items: stretch;
    }

    .pf-bottom-item-{{ section.id }} {
      flex: 1;
      min-width: 0;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  <div class="pf-container-{{ section.id }}">
    
    <div class="pf-top-{{ section.id }}">
      <div class="pf-top-left-{{ section.id }}">
        {%- if section.settings.image_1 != blank -%}
          {%- if section.settings.link_1 != blank -%}<a href="{{ section.settings.link_1 }}" class="pf-item">{%- else -%}<div class="pf-item">{%- endif -%}
          {{ section.settings.image_1 | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 66vw, 100vw', widths: '375, 550, 750, 1100, 1500' }}
          {%- if section.settings.link_1 != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endif -%}
      </div>
      
      <div class="pf-top-right-{{ section.id }}">
        {%- if section.settings.image_2 != blank -%}
          {%- if section.settings.link_2 != blank -%}<a href="{{ section.settings.link_2 }}" class="pf-item">{%- else -%}<div class="pf-item">{%- endif -%}
          {{ section.settings.image_2 | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw', widths: '375, 550, 750, 1100' }}
          {%- if section.settings.link_2 != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endif -%}
        
        {%- if section.settings.image_3 != blank -%}
          {%- if section.settings.link_3 != blank -%}<a href="{{ section.settings.link_3 }}" class="pf-item">{%- else -%}<div class="pf-item">{%- endif -%}
          {{ section.settings.image_3 | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw', widths: '375, 550, 750, 1100' }}
          {%- if section.settings.link_3 != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endif -%}
        
        {%- if section.settings.image_4 != blank -%}
          {%- if section.settings.link_4 != blank -%}<a href="{{ section.settings.link_4 }}" class="pf-item">{%- else -%}<div class="pf-item">{%- endif -%}
          {{ section.settings.image_4 | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw', widths: '375, 550, 750, 1100' }}
          {%- if section.settings.link_4 != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endif -%}
      </div>
    </div>

    <div class="pf-bottom-{{ section.id }}">
      <div class="pf-bottom-item-{{ section.id }}">
        {%- if section.settings.image_5 != blank -%}
          {%- if section.settings.link_5 != blank -%}<a href="{{ section.settings.link_5 }}" class="pf-item">{%- else -%}<div class="pf-item">{%- endif -%}
          {{ section.settings.image_5 | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw', widths: '375, 550, 750, 1100' }}
          {%- if section.settings.link_5 != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endif -%}
      </div>
      
      <div class="pf-bottom-item-{{ section.id }}">
        {%- if section.settings.image_6 != blank -%}
          {%- if section.settings.link_6 != blank -%}<a href="{{ section.settings.link_6 }}" class="pf-item">{%- else -%}<div class="pf-item">{%- endif -%}
          {{ section.settings.image_6 | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw', widths: '375, 550, 750, 1100' }}
          {%- if section.settings.link_6 != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endif -%}
      </div>
      
      <div class="pf-bottom-item-{{ section.id }}">
        {%- if section.settings.image_7 != blank -%}
          {%- if section.settings.link_7 != blank -%}<a href="{{ section.settings.link_7 }}" class="pf-item">{%- else -%}<div class="pf-item">{%- endif -%}
          {{ section.settings.image_7 | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw', widths: '375, 550, 750, 1100' }}
          {%- if section.settings.link_7 != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

