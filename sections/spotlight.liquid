{% liquid
  assign border_alpha = section.settings.border_opacity | times: 0.01
  assign card_border_alpha = section.settings.card_border_opacity | times: 0.01
  assign shadow_alpha = section.settings.shadow_opacity | times: 0.01
  assign blob_1_alpha = section.settings.blob_1_opacity | times: 0.01
  assign blob_2_alpha = section.settings.blob_2_opacity | times: 0.01
  assign radial_95 = section.settings.radial_color | color_modify: 'alpha', 0.95
  assign radial_60 = section.settings.radial_color | color_modify: 'alpha', 0.60
  assign radial_20 = section.settings.radial_color | color_modify: 'alpha', 0.20
  assign accent_35 = section.settings.accent_color | color_modify: 'alpha', 0.35
  assign accent_30 = section.settings.accent_color | color_modify: 'alpha', 0.30
  assign accent_22 = section.settings.accent_color | color_modify: 'alpha', 0.22

  assign spotlight_products = section.blocks | where: 'type', 'product'
%}

<section
  class="fulva-spotlight fulva-spotlight--{{ section.id }}{% if section.settings.hide_on_mobile %} fulva-spotlight--hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} fulva-spotlight--hide-desktop{% endif %}"
  aria-label="{{ section.settings.aria_label | escape }}"
  style="
    --fs-bg: {{ section.settings.background }};
    --fs-radial: {{ section.settings.radial_color }};
    --fs-radial-95: {{ radial_95 }};
    --fs-radial-60: {{ radial_60 }};
    --fs-radial-20: {{ radial_20 }};
    --fs-text: {{ section.settings.text_color }};
    --fs-muted: {{ section.settings.muted_text_color }};
    --fs-accent: {{ section.settings.accent_color }};
    --fs-accent-35: {{ accent_35 }};
    --fs-accent-30: {{ accent_30 }};
    --fs-accent-22: {{ accent_22 }};
    --fs-green: {{ section.settings.primary_green }};
    --fs-green-hover: {{ section.settings.primary_green_hover }};
    --fs-border: {{ section.settings.border_color | color_modify: 'alpha', border_alpha }};
    --fs-topline-1: {{ section.settings.topline_color_1 }};
    --fs-topline-2: {{ section.settings.topline_color_2 }};
    --fs-card-border: {{ section.settings.card_border_color | color_modify: 'alpha', card_border_alpha }};
    --fs-shadow: {{ section.settings.shadow_color | color_modify: 'alpha', shadow_alpha }};
    --fs-blob-1: {{ section.settings.blob_1_color | color_modify: 'alpha', blob_1_alpha }};
    --fs-blob-2: {{ section.settings.blob_2_color | color_modify: 'alpha', blob_2_alpha }};
    --fs-max: {% if section.settings.max_width > 0 %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
    --fs-px: {{ section.settings.padding_x_desktop }}px;
    --fs-py: {{ section.settings.padding_y_desktop }}px;
    --fs-px-m: {{ section.settings.padding_x_mobile }}px;
    --fs-py-m: {{ section.settings.padding_y_mobile }}px;
    --fs-gap: {{ section.settings.gap }}px;
    --fs-radius: {{ section.settings.card_radius }}px;
    --fs-img-h: {{ section.settings.image_height }}px;
    --fs-card-w: {{ section.settings.card_width_desktop }}px;
    --fs-card-w-m: {{ section.settings.card_width_mobile }}px;
  "
>
  <div class="fulva-spotlight__decor" aria-hidden="true"></div>

  <div class="fulva-spotlight__inner">
    <div class="fulva-spotlight__header">
      {% if section.settings.eyebrow != blank %}
        <div class="fulva-spotlight__eyebrow">{{ section.settings.eyebrow | escape }}</div>
      {% endif %}

      {% assign show_title_after = false %}
      {% if section.settings.show_title_after and section.settings.title_after != blank %}
        {% assign show_title_after = true %}
      {% endif %}

      {% if section.settings.title_before != blank or section.settings.title_emphasis != blank or show_title_after %}
        <h2 class="fulva-spotlight__title">
          {% if section.settings.title_before != blank %}{{ section.settings.title_before }}{% endif %}
          {% if section.settings.title_emphasis != blank %}<em>{{ section.settings.title_emphasis }}</em>{% endif %}
          {% if show_title_after %}{{ section.settings.title_after }}{% endif %}
        </h2>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <div class="fulva-spotlight__sub">{{ section.settings.subtitle }}</div>
      {% endif %}
    </div>

    <div class="fulva-spotlight__track-wrap">
      {% if section.settings.show_arrows %}
        <button class="fulva-spotlight__arrow is-prev" type="button" aria-label="Scroll left" data-fs-prev>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M14.7 5.3a1 1 0 0 1 0 1.4L9.4 12l5.3 5.3a1 1 0 1 1-1.4 1.4l-6-6a1 1 0 0 1 0-1.4l6-6a1 1 0 0 1 1.4 0z"></path>
          </svg>
        </button>
      {% endif %}

      <div
        class="fulva-spotlight__track{% if section.settings.desktop_layout == 'carousel' %} is-carousel{% endif %}{% if section.settings.mobile_layout == 'swipe' %} is-mobile-swipe{% endif %}"
        role="list"
        aria-label="{{ section.settings.aria_label | escape }}"
        data-fs-track
      >
        {% for block in spotlight_products %}
          {% liquid
            assign product = block.settings.product
            assign variant = nil
            if product != blank
              assign variant = product.selected_or_first_available_variant
            endif

            assign show_custom_badge = block.settings.show_custom_badge
            assign badge_text = block.settings.badge_text

            assign show_percent_badge = false
            assign percent_off = 0
            if product != blank and variant != blank and variant.compare_at_price > variant.price
              assign diff = variant.compare_at_price | minus: variant.price
              assign percent_off = diff | times: 100.0 | divided_by: variant.compare_at_price | round
              assign show_percent_badge = true
            endif
          %}

          <div class="fulva-spotlight__card" role="listitem" {{ block.shopify_attributes }}>
            <div class="fulva-spotlight__media">
              {% if show_percent_badge %}
                <div class="fulva-spotlight__badge">-{{ percent_off }}%</div>
              {% elsif show_custom_badge and badge_text != blank %}
                <div class="fulva-spotlight__badge">{{ badge_text | escape }}</div>
              {% endif %}

              {% if product != blank and product.featured_image != blank %}
                <img
                  class="fulva-spotlight__img"
                  src="{{ product.featured_image | image_url: width: 1200 }}"
                  srcset="
                    {{ product.featured_image | image_url: width: 360 }} 360w,
                    {{ product.featured_image | image_url: width: 540 }} 540w,
                    {{ product.featured_image | image_url: width: 720 }} 720w,
                    {{ product.featured_image | image_url: width: 900 }} 900w,
                    {{ product.featured_image | image_url: width: 1200 }} 1200w
                  "
                  sizes="(max-width: 749px) {{ section.settings.card_width_mobile }}px, 360px"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                  decoding="async"
                >
              {% else %}
                <div class="fulva-spotlight__ph" aria-hidden="true">✦</div>
              {% endif %}
            </div>

            <div class="fulva-spotlight__body">
              <div class="fulva-spotlight__name">
                {% if product != blank %}
                  {{ product.title | escape }}
                {% else %}
                  {{ block.settings.fallback_title | escape }}
                {% endif %}
              </div>

              {% if block.settings.subtitle != blank %}
                <div class="fulva-spotlight__subtitle">{{ block.settings.subtitle | escape }}</div>
              {% endif %}

              <div class="fulva-spotlight__footer">
                <div class="fulva-spotlight__prices">
                  {% if variant != blank %}
                    <span class="fulva-spotlight__price">{{ variant.price | money }}</span>
                    {% if variant.compare_at_price > variant.price %}
                      <span class="fulva-spotlight__compare">{{ variant.compare_at_price | money }}</span>
                    {% endif %}
                  {% else %}
                    <span class="fulva-spotlight__price">{{ section.settings.fallback_price | escape }}</span>
                  {% endif %}
                </div>

                {% if product != blank and variant != blank %}
                  {% form 'product', product, class: 'fulva-spotlight__form' %}
                    <input type="hidden" name="id" value="{{ variant.id }}">
                    <button class="fulva-spotlight__cart" type="submit"{% unless variant.available %} disabled{% endunless %}>
                      <span class="fulva-spotlight__plus">+</span>
                      <span>{{ section.settings.cart_label | escape }}</span>
                    </button>
                  {% endform %}
                {% else %}
                  <div class="fulva-spotlight__cart is-disabled">
                    <span class="fulva-spotlight__plus">+</span>
                    <span>{{ section.settings.cart_label | escape }}</span>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_arrows %}
        <button class="fulva-spotlight__arrow is-next" type="button" aria-label="Scroll right" data-fs-next>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M9.3 18.7a1 1 0 0 1 0-1.4L14.6 12 9.3 6.7a1 1 0 1 1 1.4-1.4l6 6a1 1 0 0 1 0 1.4l-6 6a1 1 0 0 1-1.4 0z"></path>
          </svg>
        </button>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .fulva-spotlight--{{ section.id }} {
    background: var(--fs-bg);
    border-top: 1px solid var(--fs-border);
    color: var(--fs-text);
    font-family: var(--font-body-family, sans-serif);
    position: relative;
    overflow: hidden;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__decor {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(circle at 12% 82%, var(--fs-radial-95) 0%, rgba(255, 255, 255, 0) 55%),
      radial-gradient(circle at 92% 82%, var(--fs-radial-60) 0%, rgba(255, 255, 255, 0) 60%),
      radial-gradient(circle at 50% -10%, var(--fs-radial-20) 0%, rgba(255, 255, 255, 0) 58%),
      radial-gradient(circle at 18% 96%, rgba(255, 255, 255, 0) 62%, var(--fs-accent-30) 62.5%, var(--fs-accent-30) 63%, rgba(255, 255, 255, 0) 63.5%),
      radial-gradient(circle at 86% 20%, rgba(255, 255, 255, 0) 70%, var(--fs-accent-22) 70.5%, var(--fs-accent-22) 71%, rgba(255, 255, 255, 0) 71.5%),
      linear-gradient(to right, var(--fs-accent-35), var(--fs-accent-35)) 0 62% / 100% 1px no-repeat;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__inner {
    position: relative;
    z-index: 5;
    max-width: var(--fs-max);
    margin: 0 auto;
    padding: var(--fs-py) var(--fs-px);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__header {
    text-align: center;
    max-width: 820px;
    margin: 0 auto;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fs-accent);
    font-weight: 700;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__eyebrow::before,
  .fulva-spotlight--{{ section.id }} .fulva-spotlight__eyebrow::after {
    content: '';
    width: 28px;
    height: 2px;
    background: var(--fs-accent);
    flex: 0 0 auto;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__title {
    margin: 10px 0 0;
    font-family: var(--font-body-family, sans-serif);
    font-size: 40px;
    line-height: 1.1;
    font-weight: 900;
    color: var(--fs-text);
    letter-spacing: -0.01em;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__title em {
    font-family: inherit;
    font-style: normal;
    font-weight: 900;
    color: var(--fs-green);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__sub {
    margin-top: 10px;
    color: var(--fs-muted);
    font-size: 14px;
    line-height: 1.7;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__sub p {
    margin: 0;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__track-wrap {
    margin-top: 26px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__arrow {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.10);
    background: rgba(255, 255, 255, 0.86);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    color: var(--fs-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 160ms ease, filter 160ms ease, border-color 160ms ease;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__arrow svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__arrow:hover {
    transform: translateY(-1px);
    filter: brightness(1.02);
    border-color: rgba(0, 0, 0, 0.16);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__arrow:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__track {
    display: grid;
    grid-template-columns: repeat(3, minmax(240px, var(--fs-card-w)));
    gap: var(--fs-gap);
    justify-content: center;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__track.is-carousel {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    overscroll-behavior-x: contain;
    padding: 8px 0 12px;
    cursor: grab;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__track.is-carousel::-webkit-scrollbar {
    display: none;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__track.is-dragging {
    cursor: grabbing;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__track.is-dragging .fulva-spotlight__card {
    pointer-events: none;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__card {
    border-radius: var(--fs-radius);
    overflow: hidden;
    background: #FFFFFF;
    border: 1px solid var(--fs-card-border);
    transition: transform 200ms ease;
    box-shadow: 0 14px 42px rgba(0, 0, 0, 0.12);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__track.is-carousel .fulva-spotlight__card {
    flex: 0 0 auto;
    width: var(--fs-card-w);
    scroll-snap-align: start;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__card:hover {
    transform: translateY(-2px);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__media {
    position: relative;
    height: var(--fs-img-h);
    overflow: hidden;
    background: rgba(0, 0, 0, 0.03);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 2;
    background: var(--fs-radial);
    color: #1A1A1A;
    font-size: 11px;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 999px;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: translateZ(0);
    transition: transform 260ms ease;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__card:hover .fulva-spotlight__img {
    transform: scale(1.04);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__ph {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    font-size: 44px;
    color: rgba(0, 0, 0, 0.35);
    background: linear-gradient(145deg, #f5f0e6, #ebe4d4);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__body {
    padding: 14px 14px 14px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__name {
    font-size: 14px;
    font-weight: 900;
    color: var(--fs-text);
    line-height: 1.3;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__subtitle {
    margin-top: 3px;
    font-size: 11px;
    color: var(--fs-muted);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 14px;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__prices {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    min-width: 0;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__price {
    font-size: 18px;
    font-weight: 900;
    color: var(--fs-green);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__compare {
    font-size: 13px;
    color: rgba(0, 0, 0, 0.35);
    text-decoration: line-through;
    font-weight: 600;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__form {
    margin: 0;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__cart {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 6px;
    background: var(--fs-green);
    color: #FFFFFF;
    font-size: 12px;
    font-weight: 700;
    border: 0;
    cursor: pointer;
    transition: background 160ms ease, transform 160ms ease, filter 160ms ease;
    font-family: var(--font-body-family, sans-serif);
    white-space: nowrap;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__cart:hover {
    background: var(--fs-green-hover);
    transform: translateY(-1px);
    filter: brightness(1.02);
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__cart:disabled,
  .fulva-spotlight--{{ section.id }} .fulva-spotlight__cart.is-disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
  }

  .fulva-spotlight--{{ section.id }} .fulva-spotlight__plus {
    font-weight: 900;
  }

  @media (max-width: 980px) {
    .fulva-spotlight--{{ section.id }} .fulva-spotlight__track {
      grid-template-columns: repeat(2, minmax(240px, var(--fs-card-w)));
    }
  }

  @media (max-width: 749px) {
    .fulva-spotlight--{{ section.id }} .fulva-spotlight__inner {
      padding: var(--fs-py-m) var(--fs-px-m);
    }

    .fulva-spotlight--{{ section.id }} .fulva-spotlight__title {
      font-size: 30px;
    }

    .fulva-spotlight--{{ section.id }} .fulva-spotlight__track-wrap {
      grid-template-columns: 1fr;
    }

    .fulva-spotlight--{{ section.id }} .fulva-spotlight__arrow {
      display: none;
    }

    .fulva-spotlight--{{ section.id }} .fulva-spotlight__track {
      grid-template-columns: 1fr;
    }

    .fulva-spotlight--{{ section.id }} .fulva-spotlight__track.is-mobile-swipe {
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      overscroll-behavior-x: contain;
      padding: 8px 0 12px;
    }

    .fulva-spotlight--{{ section.id }} .fulva-spotlight__track.is-mobile-swipe::-webkit-scrollbar {
      display: none;
    }

    .fulva-spotlight--{{ section.id }} .fulva-spotlight__track.is-mobile-swipe .fulva-spotlight__card {
      flex: 0 0 auto;
      width: var(--fs-card-w-m);
      scroll-snap-align: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fulva-spotlight--{{ section.id }} .fulva-spotlight__card,
    .fulva-spotlight--{{ section.id }} .fulva-spotlight__img,
    .fulva-spotlight--{{ section.id }} .fulva-spotlight__arrow,
    .fulva-spotlight--{{ section.id }} .fulva-spotlight__cart {
      transition: none;
    }
  }

  @media (max-width: 749px) {
    .fulva-spotlight--{{ section.id }}.fulva-spotlight--hide-mobile {
      display: none;
    }
  }

  @media (min-width: 750px) {
    .fulva-spotlight--{{ section.id }}.fulva-spotlight--hide-desktop {
      display: none;
    }
  }
</style>

<script>
  (() => {
    const root = document.querySelector('.fulva-spotlight--{{ section.id }}');
    if (!root) return;
    const track = root.querySelector('[data-fs-track]');
    const prevBtn = root.querySelector('[data-fs-prev]');
    const nextBtn = root.querySelector('[data-fs-next]');
    if (!track) return;

    const isCarousel = track.classList.contains('is-carousel');
    if (!isCarousel || !prevBtn || !nextBtn) return;

    const getScrollAmount = () => {
      const card = track.querySelector('.fulva-spotlight__card');
      if (!card) return 360;
      const gap = parseInt(getComputedStyle(track).gap) || 0;
      return card.offsetWidth + gap;
    };

    const updateArrows = () => {
      prevBtn.disabled = track.scrollLeft <= 10;
      const maxScroll = track.scrollWidth - track.clientWidth;
      nextBtn.disabled = track.scrollLeft >= maxScroll - 10;
    };

    prevBtn.addEventListener('click', () => track.scrollBy({ left: -getScrollAmount() * 2, behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => track.scrollBy({ left: getScrollAmount() * 2, behavior: 'smooth' }));
    track.addEventListener('scroll', updateArrows, { passive: true });
    window.addEventListener('resize', updateArrows);
    setTimeout(updateArrows, 100);

    // Mouse drag scroll (desktop)
    let isDown = false;
    let startX = 0;
    let startScrollLeft = 0;
    let dragged = false;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      dragged = false;
      startX = e.pageX - track.offsetLeft;
      startScrollLeft = track.scrollLeft;
      track.classList.add('is-dragging');
      track.style.scrollSnapType = 'none';
    });

    const endDrag = () => {
      if (!isDown) return;
      isDown = false;
      track.classList.remove('is-dragging');
      track.style.scrollSnapType = '';
      setTimeout(() => (dragged = false), 0);
    };

    track.addEventListener('mouseleave', endDrag);
    track.addEventListener('mouseup', endDrag);

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 2;
      if (Math.abs(walk) > 10) dragged = true;
      track.scrollLeft = startScrollLeft - walk;
    });

    track.addEventListener(
      'click',
      (e) => {
        if (!dragged) return;
        e.preventDefault();
        e.stopPropagation();
      },
      true
    );
  })();
</script>

{% schema %}
{
  "name": "Fulva spotlight",
  "settings": [
