<div class="availability-banner" style="
  --ab-height: {{ section.settings.section_height }}px;
  --ab-bg: {{ section.settings.background_color }};
  --ab-text-color: {{ section.settings.text_color }};
">
  <div class="availability-banner__container">
    <div class="availability-banner__text">
      {{ section.settings.heading_text }}
    </div>
    
    <div class="availability-banner__images">
      {%- for block in section.blocks -%}
        {%- if block.settings.image != blank -%}
          {%- assign alt = block.settings.alt_text | default: block.settings.image.alt -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="ab-image-link{% if block.settings.full_width_mobile %} ab-image--full-mobile{% endif %}" {{ block.shopify_attributes }}>
              <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ alt | escape }}">
            </a>
          {%- else -%}
            <div class="ab-image-wrapper{% if block.settings.full_width_mobile %} ab-image--full-mobile{% endif %}" {{ block.shopify_attributes }}>
              <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ alt | escape }}">
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{{ 'availability-banner.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Fulva Availability Banner",
  "settings": [
    {
      "type": "range",
      "id": "section_height",
      "label": "Section Height (Desktop)",
      "min": 32,
      "max": 232,
      "step": 2,
      "default": 132,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F8FBF8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "AVAILABLE ACROSS INDIA"
    }
  ],
  "blocks": [
    {
      "type": "platform_image",
      "name": "Platform Image",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Platform Logo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text (optional)"
        },
        {
          "type": "checkbox",
          "id": "full_width_mobile",
          "label": "Full width on mobile",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fulva Availability Banner",
      "blocks": [
        { "type": "platform_image" },
        { "type": "platform_image" },
        { "type": "platform_image" }
      ]
    }
  ]
}
{% endschema %}
