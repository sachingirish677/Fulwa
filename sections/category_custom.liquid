{% liquid
  assign border_alpha = section.settings.border_opacity | times: 0.01
  assign card_border_alpha = section.settings.card_border_opacity | times: 0.01
  assign card_shadow_alpha = section.settings.card_shadow_opacity | times: 0.01

  assign category_blocks = section.blocks | where: 'type', 'category'
%}

<fulva-categories
  class="fulva-categories fulva-categories--{{ section.id }}{% if section.settings.hide_on_mobile %} fulva-categories--hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} fulva-categories--hide-desktop{% endif %}"
  aria-label="{{ section.settings.aria_label | escape }}"
  style="
    --fc-bg: {{ section.settings.background }};
    --fc-text: {{ section.settings.text_color }};
    --fc-accent: {{ section.settings.accent_color }};
    --fc-border: {{ section.settings.border_color | color_modify: 'alpha', border_alpha }};
    --fc-card-border: {{ section.settings.card_border_color | color_modify: 'alpha', card_border_alpha }};
    --fc-card-title: {{ section.settings.card_title_color }};
    --fc-shadow: {{ section.settings.shadow_color | color_modify: 'alpha', card_shadow_alpha }};
    --fc-max: {% if section.settings.max_width > 0 %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
    --fc-px: {{ section.settings.padding_x_desktop }}px;
    --fc-py: {{ section.settings.padding_y_desktop }}px;
    --fc-px-m: {{ section.settings.padding_x_mobile }}px;
    --fc-py-m: {{ section.settings.padding_y_mobile }}px;
    --fc-gap: {{ section.settings.gap }}px;
    --fc-card-w: {{ section.settings.card_width_desktop }}px;
    --fc-card-h: {{ section.settings.card_height_desktop }}px;
    --fc-thumb: {{ section.settings.thumb_size_desktop }}px;
    --fc-card-w-m: {{ section.settings.card_width_mobile }}px;
    --fc-card-h-m: {{ section.settings.card_height_mobile }}px;
    --fc-thumb-m: {{ section.settings.thumb_size_mobile }}px;
    --fc-radius: {{ section.settings.radius }}px;
  "
>
  <div class="fulva-categories__inner">
    <div class="fulva-categories__label">
      {% if section.settings.heading != blank %}
        <h2 class="fulva-categories__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.eyebrow != blank %}
        <div class="fulva-categories__eyebrow">{{ section.settings.eyebrow | escape }}</div>
      {% endif %}


    </div>

    <div class="fulva-categories__track" role="list" aria-label="{{ section.settings.aria_label | escape }}" data-fc-track>
      {% for block in category_blocks %}
        {% liquid
          assign col = block.settings.collection
          assign url = block.settings.url
          if col != blank
            assign url = col.url
          endif

          assign label = block.settings.label
          if label == blank and col != blank
            assign label = col.title
          endif
          if label == blank
            assign label = 'Category'
          endif

          assign img = block.settings.image
          if img == blank and col != blank
            assign img = col.image | default: col.featured_image
          endif

          assign placeholder_letter = label | strip_html | strip | slice: 0, 1 | upcase
        %}

        {% if url != blank %}
          <a class="fulva-categories__card" href="{{ url }}" role="listitem" {{ block.shopify_attributes }} style="--fc-card-bg: linear-gradient(180deg, {{ block.settings.card_bg_top }} 0%, {{ block.settings.card_bg_top }} {{ block.settings.card_bg_gradient_start }}%, {{ block.settings.card_bg_bottom }} 100%);">
        {% else %}
          <div class="fulva-categories__card" role="listitem" {{ block.shopify_attributes }} style="--fc-card-bg: linear-gradient(180deg, {{ block.settings.card_bg_top }} 0%, {{ block.settings.card_bg_top }} {{ block.settings.card_bg_gradient_start }}%, {{ block.settings.card_bg_bottom }} 100%);">
        {% endif %}
            <div class="fulva-categories__card-name">{{ label | escape }}</div>
            <div class="fulva-categories__thumb" aria-hidden="{% if img != blank %}false{% else %}true{% endif %}">
              {% if img != blank %}
                <img
                  class="fulva-categories__thumb-img"
                  src="{{ img | image_url: width: 240 }}"
                  srcset="
                    {{ img | image_url: width: 120 }} 120w,
                    {{ img | image_url: width: 180 }} 180w,
                    {{ img | image_url: width: 240 }} 240w,
                    {{ img | image_url: width: 320 }} 320w
                  "
                  sizes="(max-width: 749px) {{ section.settings.thumb_size_mobile }}px, {{ section.settings.thumb_size_desktop }}px"
                  width="{{ img.width }}"
                  height="{{ img.height }}"
                  alt="{{ label | escape }}"
                  loading="lazy"
                  decoding="async"
                >
              {% else %}
                <div class="fulva-categories__thumb-placeholder" aria-hidden="true">{{ placeholder_letter }}</div>
              {% endif %}
            </div>
        {% if url != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="fulva-categories__dots" data-fc-dots>
      {% for block in category_blocks %}
        <button type="button" class="fulva-categories__dot{% if forloop.first %} is-active{% endif %}" aria-label="Go to category {{ forloop.index }}" data-index="{{ forloop.index0 }}"></button>
      {% endfor %}
    </div>
  </div>
</fulva-categories>

{{ 'category-custom.css' | asset_url | stylesheet_tag }}

<script>
  if (!customElements.get('fulva-categories')) {
    customElements.define('fulva-categories', class extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('[data-fc-track]');
        this.prevBtn = this.querySelector('[data-fc-prev]');
        this.nextBtn = this.querySelector('[data-fc-next]');
        this.dots = this.querySelectorAll('[data-fc-dots] .fulva-categories__dot');
        this.dotsContainer = this.querySelector('[data-fc-dots]');
        
        if (!this.track) return;

        this.updateArrowStates = this.updateArrowStates.bind(this);
        this.updateDots = this.updateDots.bind(this);
        
        if (this.prevBtn && this.nextBtn) {
          this.prevBtn.addEventListener('click', () => {
            this.track.scrollBy({ left: -this.getScrollAmount() * 2, behavior: 'smooth' });
          });
          this.nextBtn.addEventListener('click', () => {
            this.track.scrollBy({ left: this.getScrollAmount() * 2, behavior: 'smooth' });
          });
        }

        if (this.dots) {
          this.dots.forEach((dot) => {
            dot.addEventListener('click', (e) => {
              const index = parseInt(e.currentTarget.getAttribute('data-index'));
              const card = this.track.querySelectorAll('.fulva-categories__card')[index];
              if (card) {
                const scrollLeft = card.offsetLeft - this.track.offsetLeft - parseInt(window.getComputedStyle(this.track).paddingLeft);
                this.track.scrollTo({ left: scrollLeft, behavior: 'smooth' });
              }
            });
          });
        }

        this.track.addEventListener('scroll', () => {
          this.updateArrowStates();
          this.updateDots();
        }, { passive: true });
        
        setTimeout(() => {
          this.updateArrowStates();
          this.updateDots();
        }, 100);
        
        window.addEventListener('resize', () => {
          this.updateArrowStates();
          this.updateDots();
        });

        // Desktop Mouse Drag to Scroll
        this.isDown = false;
        this.startX = 0;
        this.scrollLeft = 0;

        this.track.addEventListener('mousedown', (e) => {
          if (e.button !== 0) return; // Only left click
          this.isDown = true;
          this.track.classList.add('is-dragging');
          this.startX = e.pageX - this.track.offsetLeft;
          this.scrollLeft = this.track.scrollLeft;
          this.track.style.scrollSnapType = 'none';
        });

        this.track.addEventListener('mouseleave', () => {
          this.isDown = false;
          this.track.classList.remove('is-dragging');
          this.track.style.scrollSnapType = '';
        });

        this.track.addEventListener('mouseup', () => {
          this.isDown = false;
          this.track.classList.remove('is-dragging');
          this.track.style.scrollSnapType = '';
        });

        this.track.addEventListener('mousemove', (e) => {
          if (!this.isDown) return;
          e.preventDefault();
          const x = e.pageX - this.track.offsetLeft;
          const walk = (x - this.startX) * 2; // Scroll speed multiplier
          this.track.scrollLeft = this.scrollLeft - walk;
        });

        // Prevent links from triggering when dragging
        const cards = this.track.querySelectorAll('.fulva-categories__card');
        cards.forEach(card => {
          card.addEventListener('click', (e) => {
            if (this.track.classList.contains('is-dragging')) {
              e.preventDefault();
            }
          });
        });
      }

      getScrollAmount() {
        const card = this.track.querySelector('.fulva-categories__card');
        if (!card) return 200;
        const gap = parseInt(window.getComputedStyle(this.track).gap) || 0;
        return card.offsetWidth + gap;
      }

      updateArrowStates() {
        if (this.prevBtn) this.prevBtn.disabled = this.track.scrollLeft <= 10;
        if (this.nextBtn) {
          const maxScroll = this.track.scrollWidth - this.track.clientWidth;
          this.nextBtn.disabled = this.track.scrollLeft >= maxScroll - 10;
        }
      }

      updateDots() {
        if (!this.dots || this.dots.length === 0 || !this.dotsContainer) return;
        const scrollRatio = this.track.clientWidth / this.track.scrollWidth;
        
        // Hide dots if there's nothing to scroll
        if (scrollRatio >= 1) {
          this.dotsContainer.style.display = 'none';
          return;
        } else {
          this.dotsContainer.style.display = 'flex';
        }
        
        const scrollProgress = this.track.scrollLeft / (this.track.scrollWidth - this.track.clientWidth);
        // Calculate the index based on scroll progress
        let activeIndex = Math.round(scrollProgress * (this.dots.length - 1));
        // Bound the active index
        activeIndex = Math.max(0, Math.min(activeIndex, this.dots.length - 1));

        this.dots.forEach((dot, index) => {
          if (index === activeIndex) {
            dot.classList.add('is-active');
          } else {
            dot.classList.remove('is-active');
          }
        });
      }

      disconnectedCallback() {
        window.removeEventListener('resize', this.updateArrowStates);
        window.removeEventListener('resize', this.updateScrollbar);
      }
    });
  }
</script>

{% schema %}
{
  "name": "Fulva categories",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "Browse categories" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "All <em>Categories</em>" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse by type" },

    { "type": "header", "content": "Layout" },

    { "type": "range", "id": "max_width", "label": "Max width (0 = full width)", "min": 0, "max": 1800, "step": 20, "default": 0 },
    { "type": "range", "id": "padding_x_desktop", "label": "Padding X desktop (px)", "min": 0, "max": 80, "step": 2, "default": 64 },
    { "type": "range", "id": "padding_y_desktop", "label": "Padding Y desktop (px)", "min": 0, "max": 60, "step": 2, "default": 30 },
    { "type": "range", "id": "padding_x_mobile", "label": "Padding X mobile (px)", "min": 0, "max": 30, "step": 1, "default": 16 },
    { "type": "range", "id": "padding_y_mobile", "label": "Padding Y mobile (px)", "min": 0, "max": 40, "step": 1, "default": 16 },
    { "type": "range", "id": "gap", "label": "Card gap (px)", "min": 8, "max": 30, "step": 1, "default": 14 },
    { "type": "range", "id": "radius", "label": "Card radius (px)", "min": 0, "max": 20, "step": 1, "default": 12 },

    { "type": "header", "content": "Card sizes" },
    { "type": "range", "id": "card_width_desktop", "label": "Card width desktop (px)", "min": 90, "max": 200, "step": 2, "default": 130 },
    { "type": "range", "id": "card_height_desktop", "label": "Card height desktop (px)", "min": 110, "max": 220, "step": 2, "default": 146 },
    { "type": "range", "id": "thumb_size_desktop", "label": "Thumbnail size desktop (px)", "min": 70, "max": 150, "step": 2, "default": 106 },
    { "type": "range", "id": "card_width_mobile", "label": "Card width mobile (px)", "min": 84, "max": 170, "step": 2, "default": 112 },
    { "type": "range", "id": "card_height_mobile", "label": "Card height mobile (px)", "min": 100, "max": 200, "step": 2, "default": 132 },
    { "type": "range", "id": "thumb_size_mobile", "label": "Thumbnail size mobile (px)", "min": 64, "max": 130, "step": 2, "default": 92 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background", "label": "Section background", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#1A1A1A" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#D4A843" },
    { "type": "color", "id": "border_color", "label": "Section border", "default": "#000000" },
    { "type": "range", "id": "border_opacity", "label": "Section border opacity (%)", "min": 0, "max": 40, "step": 2, "default": 10 },


    { "type": "color", "id": "card_border_color", "label": "Card border", "default": "#000000" },
    { "type": "range", "id": "card_border_opacity", "label": "Card border opacity (%)", "min": 0, "max": 30, "step": 1, "default": 5 },
    { "type": "color", "id": "card_title_color", "label": "Card title color", "default": "#1B5E2F" },
    { "type": "color", "id": "shadow_color", "label": "Hover shadow color", "default": "#000000" },
    { "type": "range", "id": "card_shadow_opacity", "label": "Hover shadow opacity (%)", "min": 0, "max": 20, "step": 1, "default": 7 },

    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Hide on desktop", "default": false }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "limit": 12,
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "label", "label": "Custom label (optional)" },
        { "type": "image_picker", "id": "image", "label": "Custom image (optional)" },
        { "type": "url", "id": "url", "label": "Custom link (optional)" },
        { "type": "color", "id": "card_bg_top", "label": "Card background top", "default": "#FFFFFF" },
        { "type": "color", "id": "card_bg_bottom", "label": "Card background bottom", "default": "#F6F6F6" },
        { "type": "range", "id": "card_bg_gradient_start", "label": "Gradient start position (%)", "min": 0, "max": 100, "step": 5, "default": 55 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fulva categories",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
