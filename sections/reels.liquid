{{ 'fulva-reels.css' | asset_url | stylesheet_tag }}


{% liquid
  assign border_alpha = section.settings.border_opacity | times: 0.01
  assign bg_color = section.settings.background
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
  assign border_color = section.settings.border_color | color_modify: 'alpha', border_alpha

  assign ig_href = section.settings.ig_link
  if ig_href != blank
    unless ig_href contains '://'
      assign ig_href = 'https://' | append: ig_href
    endunless
  endif

  assign reel_blocks = section.blocks | where: 'type', 'reel'
%}

<section
  class="fulva-reels fulva-reels--{{ section.id }}{% if section.settings.hide_on_mobile %} fulva-reels--hide-mobile{% endif %}{% if section.settings.hide_on_desktop %} fulva-reels--hide-desktop{% endif %}"
  aria-label="{{ section.settings.aria_label | escape }}"
  style="
    --fr-bg: {{ bg_color }};
    --fr-text: {{ text_color }};
    --fr-accent: {{ accent_color }};
    --fr-border: {{ border_color }};
    --fr-max: {% if section.settings.max_width > 0 %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
    --fr-px: {{ section.settings.padding_x_desktop }}px;
    --fr-py: {{ section.settings.padding_y_desktop }}px;
    --fr-px-m: {{ section.settings.padding_x_mobile }}px;
    --fr-py-m: {{ section.settings.padding_y_mobile }}px;
    --fr-card-w: {{ section.settings.card_width_desktop }}px;
    --fr-card-h: {{ section.settings.card_height_desktop }}px;
    --fr-card-w-m: {{ section.settings.card_width_mobile }}px;
    --fr-card-h-m: {{ section.settings.card_height_mobile }}px;
    --fr-gap: {{ section.settings.gap }}px;
    --fr-radius: {{ section.settings.radius }}px;
    --fr-ig-grad: linear-gradient(45deg, {{ section.settings.ig_grad_1 }} 0%, {{ section.settings.ig_grad_2 }} 33%, {{ section.settings.ig_grad_3 }} 66%, {{ section.settings.ig_grad_4 }} 100%);
    --fr-modal-py-desktop: {{ section.settings.modal_padding_y_desktop }}px;
    --fr-modal-py-mobile: {{ section.settings.modal_padding_y_mobile }}px;
  "
>
  <div class="fulva-reels__inner">
    <!-- Header -->
    {% if section.settings.show_header %}
      <div class="fulva-reels-header">
        <div class="fulva-reels-header-left">
          {% if section.settings.eyebrow != blank %}
            <div class="fulva-reels-eyebrow">{{ section.settings.eyebrow | escape }}</div>
          {% endif %}
          <div class="fulva-reels-title-row">
            {% if section.settings.heading_1 != blank or section.settings.heading_2 != blank or section.settings.heading_3 != blank %}
              <h2 class="fulva-reels-title">
                {% if section.settings.heading_1 != blank %}<span style="color: {{ section.settings.heading_1_color }};">{{ section.settings.heading_1 }}</span> {% endif %}
                {% if section.settings.heading_2 != blank %}<span style="color: {{ section.settings.heading_2_color }};">{{ section.settings.heading_2 }}</span> {% endif %}
                {% if section.settings.heading_3 != blank %}<span style="color: {{ section.settings.heading_3_color }};">{{ section.settings.heading_3 }}</span>{% endif %}
              </h2>
            {% endif %}
            {% if section.settings.ig_handle != blank and section.settings.ig_link != blank %}
              <a href="{{ ig_href }}" target="_blank" rel="noopener" class="fulva-ig-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
                {{ section.settings.ig_handle | escape }}
              </a>
            {% endif %}
          </div>
        </div>

        {% if section.settings.show_filters %}
          <div class="fulva-ugc-filter">
            <button class="fulva-filter-chip active">All</button>
            {% if section.settings.filter_1 != blank %}<button class="fulva-filter-chip">{{ section.settings.filter_1 | escape }}</button>{% endif %}
            {% if section.settings.filter_2 != blank %}<button class="fulva-filter-chip">{{ section.settings.filter_2 | escape }}</button>{% endif %}
            {% if section.settings.filter_3 != blank %}<button class="fulva-filter-chip">{{ section.settings.filter_3 | escape }}</button>{% endif %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <!-- Reels track -->
    <div class="fulva-reels-track-wrap">
      {% if section.settings.show_arrows %}
        <button class="fulva-reels-nav nav-left" aria-label="Scroll left" data-fr-prev>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12H4M4 12L10 6M4 12L10 18"></path></svg>
        </button>
      {% endif %}

      <div class="fulva-reels-track" id="reelsTrack-{{ section.id }}" data-fr-track>
        {% for block in reel_blocks %}
          {% liquid
            assign img = block.settings.image
            assign mp4_url = block.settings.mp4_url
            assign category = block.settings.category
            assign linked_product = block.settings.linked_product
            
            assign pd_title = linked_product.title | default: ''
            assign pd_url = linked_product.url | default: ''
            assign pd_img = linked_product.featured_image | image_url: width: 100 | default: ''
            assign pd_price = linked_product.price | money | default: ''
            assign pd_compare = linked_product.compare_at_price | money | default: ''
            
            assign pd_discount = 0
            if linked_product.compare_at_price > linked_product.price
              assign pd_discount = linked_product.compare_at_price | minus: linked_product.price | times: 100.0 | divided_by: linked_product.compare_at_price | round
            endif
          %}
          <div class="fulva-reel-card" data-fr-category="{{ category | escape }}" data-video="{{ mp4_url }}" data-p-title="{{ pd_title | escape }}" data-p-url="{{ pd_url }}" data-p-img="{{ pd_img }}" data-p-price="{{ pd_price | escape }}" data-p-compare="{{ pd_compare | escape }}" data-p-discount="{{ pd_discount }}" data-btn-url="{{ block.settings.button_link }}" data-btn-label="{{ block.settings.button_label | escape }}" {{ block.shopify_attributes }}>
            {% if mp4_url != blank %}
              <video class="reel-thumb" autoplay muted loop playsinline webkit-playsinline preload="metadata"{% if img != blank %} poster="{{ img | image_url: width: 600 }}"{% endif %}>
                <source src="{{ mp4_url }}" type="video/mp4">
              </video>
            {% elsif img != blank %}
              <img class="reel-thumb" src="{{ img | image_url: width: 400 }}" alt="{{ img.alt | escape }}" loading="lazy">
            {% else %}
              <div class="fulva-reel-placeholder">✨</div>
            {% endif %}

            {% if ig_href != blank %}
              <a class="fulva-reel-ig-icon" href="{{ ig_href }}" target="_blank" rel="noopener" aria-label="Open Instagram">
                <img src="{{ 'reel-icon.png' | asset_url }}" alt="Instagram" width="28" height="28">
              </a>
            {% else %}
              <div class="fulva-reel-ig-icon" aria-hidden="true">
                <img src="{{ 'reel-icon.png' | asset_url }}" alt="Instagram" width="28" height="28">
              </div>
            {% endif %}
            
            {% if block.settings.views != blank %}
              <span class="fulva-reel-views">{{ block.settings.views | escape }}</span>
            {% endif %}

            <div class="fulva-reel-bottom">
              {% if block.settings.username != blank %}
                <span class="fulva-reel-user">{{ block.settings.username | escape }}</span>
              {% endif %}
              {% if block.settings.product_tag != blank %}
                <span class="fulva-reel-product-tag">{{ block.settings.product_tag | escape }}</span>
              {% endif %}
              <div class="fulva-reel-actions">
                {% if block.settings.button_link != blank and block.settings.button_label != blank %}
                  <a href="{{ block.settings.button_link }}" class="fulva-reel-buy">{{ block.settings.button_label | escape }}</a>
                {% else %}
                  <div></div>
                {% endif %}
                {% if block.settings.likes != blank %}
                  <span class="fulva-reel-likes"><span class="heart">♥</span> {{ block.settings.likes | escape }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_arrows %}
        <button class="fulva-reels-nav nav-right" aria-label="Scroll right" data-fr-next>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12H20M20 12L14 6M20 12L14 18"></path></svg>
        </button>
      {% endif %}
    </div>
  </div>

  <!-- Modal -->
  <div class="fr-modal" id="fr-modal-{{ section.id }}" aria-hidden="true">
    <div class="fr-modal__backdrop" data-fr-close></div>
    <div class="fr-modal__content">
      <div class="fr-modal__header">
        <button class="fr-modal__btn fr-modal__minimize" data-fr-close aria-label="Minimize">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14h6v6M20 10h-6V4M14 10l7-7M3 21l7-7"/></svg>
        </button>
        <div class="fr-modal__header-right">
          <button class="fr-modal__btn fr-modal__mute" data-fr-mute aria-label="Toggle Sound">
            <svg class="fr-icon-unmute" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
            <svg class="fr-icon-mute" style="display:none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg>
          </button>
          <button class="fr-modal__btn fr-modal__close" data-fr-close aria-label="Close">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
          </button>
        </div>
      </div>
      
      <button class="fr-modal__nav fr-modal__nav--prev" data-fr-modal-prev aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"></path></svg>
      </button>
      
      <video class="fr-modal__video" id="fr-modal-video-{{ section.id }}" loop playsinline></video>
      
      <button class="fr-modal__nav fr-modal__nav--next" data-fr-modal-next aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"></path></svg>
      </button>
      
      <div class="fr-modal__product" id="fr-modal-product-{{ section.id }}">
        <!-- Injected via JS -->
      </div>
    </div>
  </div>
</section>


<script>
  const initReels_{{ section.id | replace: '-', '_' }} = () => {
    const root = document.querySelector('.fulva-reels--{{ section.id }}');
    if (!root || root.getAttribute('data-initialized') === 'true') return;
    
    // Slider logic
    const track = root.querySelector('[data-fr-track]');
    const prevBtn = root.querySelector('[data-fr-prev]');
    const nextBtn = root.querySelector('[data-fr-next]');
    if (!track) return;

    root.setAttribute('data-initialized', 'true');

    const prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const videos = track.querySelectorAll('video.reel-thumb');
    const attemptPlay = (v) => {
      if (prefersReducedMotion) {
        v.controls = true;
        return;
      }
      try {
        v.muted = true;
        v.loop = true;
        v.setAttribute('muted', '');
        v.setAttribute('playsinline', '');
        v.setAttribute('webkit-playsinline', '');
        v.playsInline = true;
      } catch (e) {}

      const p = v.play && v.play();
      if (p && typeof p.catch === 'function') {
        p.catch(() => {
          const card = v.closest && v.closest('.fulva-reel-card');
          if (card) card.classList.add('is-video-manual');
          v.controls = true;
        });
      }
    };

    videos.forEach((v) => {
      v.addEventListener('loadedmetadata', () => attemptPlay(v), { passive: true });
      v.addEventListener('canplay', () => attemptPlay(v), { passive: true });
    });

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const v = entry.target;
          if (entry.isIntersecting) {
            attemptPlay(v);
          } else {
            try { v.pause(); } catch (e) {}
          }
        });
      }, { root: track, threshold: 0.6 });
      videos.forEach((v) => io.observe(v));
    } else {
      videos.forEach((v) => attemptPlay(v));
    }

    // Filter logic
    const chips = root.querySelectorAll('.fulva-filter-chip');
    const cards = Array.from(track.querySelectorAll('.fulva-reel-card'));
    const applyFilter = (label) => {
      const key = (label || '').trim();
      const isAll = key.toLowerCase() === 'all';
      cards.forEach((card) => {
        const cat = (card.getAttribute('data-fr-category') || '').trim();
        const match = isAll || (cat !== '' && cat === key);
        card.classList.toggle('is-hidden', !match);
        if (!match) {
          const v = card.querySelector && card.querySelector('video.reel-thumb');
          if (v) {
            try { v.pause(); } catch (e) {}
          }
        }
      });
      setTimeout(updateArrowStates, 100);
    };

    if (chips.length) {
      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          chips.forEach((c) => c.classList.remove('active'));
          chip.classList.add('active');
          applyFilter(chip.textContent || 'All');
        });
      });
    }

    // Desktop arrow navigation
    const getScrollAmount = () => {
      const firstVisible = track.querySelector('.fulva-reel-card:not(.is-hidden)');
      if (!firstVisible) return 300;
      const style = getComputedStyle(track);
      const gap = parseInt(style.gap) || 0;
      return firstVisible.offsetWidth + gap;
    };

    const updateArrowStates = () => {
      if (!track || !prevBtn || !nextBtn) return;
      const scrollLeft = track.scrollLeft;
      const maxScroll = track.scrollWidth - track.clientWidth;
      
      prevBtn.disabled = scrollLeft <= 10;
      nextBtn.disabled = scrollLeft >= maxScroll - 10;
      
      prevBtn.style.opacity = prevBtn.disabled ? '0.3' : '1';
      prevBtn.style.pointerEvents = prevBtn.disabled ? 'none' : 'auto';
      nextBtn.style.opacity = nextBtn.disabled ? '0.3' : '1';
      nextBtn.style.pointerEvents = nextBtn.disabled ? 'none' : 'auto';
    };

    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
        setTimeout(updateArrowStates, 600);
      });
      nextBtn.addEventListener('click', () => {
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
        setTimeout(updateArrowStates, 600);
      });
      track.addEventListener('scroll', updateArrowStates, { passive: true });
      if (window.ResizeObserver) {
        new ResizeObserver(() => updateArrowStates()).observe(track);
      }
      setTimeout(updateArrowStates, 1000);
    }

    // Mouse Drag
    const canDrag = window.matchMedia && window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    if (canDrag) {
      let isDown = false;
      let startX;
      let scrollL;
      let isDragged = false;

      track.addEventListener('mousedown', (e) => {
        isDown = true;
        isDragged = false;
        startX = e.pageX - track.offsetLeft;
        scrollL = track.scrollLeft;
      });
      track.addEventListener('mouseleave', () => {
        isDown = false;
        track.classList.remove('is-dragging');
        track.style.scrollSnapType = '';
      });
      track.addEventListener('mouseup', () => {
        isDown = false;
        track.classList.remove('is-dragging');
        track.style.scrollSnapType = '';
      });
      track.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        const x = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 2;
        if (Math.abs(walk) > 10) {
          if (!isDragged) {
            isDragged = true;
            track.classList.add('is-dragging');
            track.style.scrollSnapType = 'none';
          }
        }
        if (isDragged) {
          e.preventDefault();
          track.scrollLeft = scrollL - walk;
        }
      });

      track.querySelectorAll('.fulva-reel-card').forEach(card => {
        card.addEventListener('click', (e) => {
          if (isDragged) e.preventDefault();
        });
      });
    }

    // Modal logic
    const modal = root.querySelector('#fr-modal-{{ section.id }}');
    const modalVideo = root.querySelector('#fr-modal-video-{{ section.id }}');
    const modalProduct = root.querySelector('#fr-modal-product-{{ section.id }}');
    const muteBtn = root.querySelector('[data-fr-mute]');
    const closeBtns = root.querySelectorAll('[data-fr-close]');
    const prevModalBtn = root.querySelector('[data-fr-modal-prev]');
    const nextModalBtn = root.querySelector('[data-fr-modal-next]');
    
    let isMuted = false;
    let currentCardIndex = -1;

    if (modal && modalVideo) {
      const getVisibleCards = () => Array.from(track.querySelectorAll('.fulva-reel-card:not(.is-hidden)'));
      
      const updateModalNav = (visibleCards) => {
        if (!prevModalBtn || !nextModalBtn) return;
        prevModalBtn.style.display = currentCardIndex > 0 ? 'flex' : 'none';
        nextModalBtn.style.display = currentCardIndex < visibleCards.length - 1 ? 'flex' : 'none';
      };

      const openModal = (card) => {
        const videoSrc = card.getAttribute('data-video');
        if (!videoSrc) return;
        
        const visibleCards = getVisibleCards();
        currentCardIndex = visibleCards.indexOf(card);
        updateModalNav(visibleCards);

        const pTitle = card.getAttribute('data-p-title');
        const pUrl = card.getAttribute('data-p-url');
        const pImg = card.getAttribute('data-p-img');
        const pPrice = card.getAttribute('data-p-price');
        const pCompare = card.getAttribute('data-p-compare');
        const pDiscount = card.getAttribute('data-p-discount');
        const btnUrl = card.getAttribute('data-btn-url') || pUrl;
        const btnLabel = card.getAttribute('data-btn-label') || 'Buy Now';

        modalVideo.src = videoSrc;
        modalVideo.muted = isMuted;
        
        if ((pTitle && pUrl) || btnUrl) {
          let priceHtml = '';
          if (pTitle && pUrl) {
            modalProduct.classList.add('has-product-info');
            priceHtml = `<strong>${pPrice}</strong>`;
            if (pCompare) {
              priceHtml += ` <s style="color:#888; font-size:10px; margin-left:4px;">${pCompare}</s>`;
              if (pDiscount > 0) {
                priceHtml += ` <span style="color:#28a745; font-size:10px; margin-left:4px;">${pDiscount}% Off</span>`;
              }
            }
          } else {
            modalProduct.classList.remove('has-product-info');
          }
          
          let innerHtml = '';
          if (pTitle && pUrl) {
            innerHtml = `
              <div class="fr-mp-inner">
                ${pImg ? `<img src="${pImg}" alt="" class="fr-mp-img">` : ''}
                <div class="fr-mp-info">
                  <div class="fr-mp-title">${pTitle} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;margin-left:4px;vertical-align:middle;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg></div>
                  <div class="fr-mp-price">${priceHtml}</div>
                </div>
              </div>
            `;
          }
          
          modalProduct.innerHTML = `
            ${innerHtml}
            <a href="${btnUrl}" class="fr-mp-btn">${btnLabel}</a>
          `;
          modalProduct.style.display = 'block';
        } else {
          modalProduct.style.display = 'none';
        }

        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        
        const playPromise = modalVideo.play();
        if (playPromise !== undefined) {
          playPromise.catch(() => {
            modalVideo.muted = true;
            isMuted = true;
            updateMuteIcon();
            modalVideo.play();
          });
        }
      };

      const closeModal = () => {
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        modalVideo.pause();
        modalVideo.src = '';
      };

      const updateMuteIcon = () => {
        const unmuteIcon = muteBtn.querySelector('.fr-icon-unmute');
        const muteIcon = muteBtn.querySelector('.fr-icon-mute');
        if (isMuted) {
          unmuteIcon.style.display = 'none';
          muteIcon.style.display = 'block';
        } else {
          unmuteIcon.style.display = 'block';
          muteIcon.style.display = 'none';
        }
      };

      muteBtn.addEventListener('click', () => {
        isMuted = !isMuted;
        modalVideo.muted = isMuted;
        updateMuteIcon();
      });

      closeBtns.forEach(btn => btn.addEventListener('click', closeModal));

      const goPrev = () => {
        const visibleCards = getVisibleCards();
        if (currentCardIndex > 0) openModal(visibleCards[currentCardIndex - 1]);
      };

      const goNext = () => {
        const visibleCards = getVisibleCards();
        if (currentCardIndex < visibleCards.length - 1) openModal(visibleCards[currentCardIndex + 1]);
      };

      if (prevModalBtn) prevModalBtn.addEventListener('click', goPrev);
      if (nextModalBtn) nextModalBtn.addEventListener('click', goNext);

      cards.forEach(card => {
        card.addEventListener('click', (e) => {
          if (window.matchMedia && window.matchMedia('(hover: hover) and (pointer: fine)').matches && track.classList.contains('is-dragging')) return;
          // Prevent opening if they click the IG icon or Buy button inside the card itself
          if (e.target.closest('.fulva-reel-ig-icon') || e.target.closest('.fulva-reel-buy')) return;
          openModal(card);
        });
      });
    }

    track.addEventListener('touchstart', () => { track.style.scrollSnapType = 'none'; }, { passive: true });
    track.addEventListener('touchend', () => { track.style.scrollSnapType = ''; }, { passive: true });
  };

  document.addEventListener('DOMContentLoaded', initReels_{{ section.id | replace: '-', '_' }});
  document.addEventListener('shopify:section:load', initReels_{{ section.id | replace: '-', '_' }});
  // Execute now for normal loads
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initReels_{{ section.id | replace: '-', '_' }}();
  }

</script>

{% schema %}
{
  "name": "Fulva Reels",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "Instagram Reels" },
    { "type": "header", "content": "Header settings" },
    { "type": "checkbox", "id": "show_header", "label": "Show header section", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real People, Real Moments" },
    { "type": "inline_richtext", "id": "heading_1", "label": "Heading Part 1", "default": "The" },
    { "type": "color", "id": "heading_1_color", "label": "Heading Part 1 Color", "default": "#1A1A1A" },
    { "type": "inline_richtext", "id": "heading_2", "label": "Heading Part 2", "default": "<em>Halwa</em>" },
    { "type": "color", "id": "heading_2_color", "label": "Heading Part 2 Color", "default": "#1A1A1A" },
    { "type": "inline_richtext", "id": "heading_3", "label": "Heading Part 3", "default": "Diaries" },
