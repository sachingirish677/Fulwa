{{ 'faq-with-image.css' | asset_url | stylesheet_tag }}
<script src="{{ 'faq-with-image.js' | asset_url }}" defer="defer"></script>

<style>
  .faq-section-wrapper--{{ section.id }} {
    {% if section.settings.use_gradient_bg %}
      background: 
        radial-gradient(ellipse 120% 50% at 50% 25%, {{ section.settings.bg_gradient_2 }} 0%, {{ section.settings.bg_gradient_3 }} 70%, transparent 100%),
        linear-gradient(180deg, transparent 0%, {{ section.settings.bg_gradient_3 }} 100%),
        {{ section.settings.bg_gradient_1 }};
    {% else %}
      background-color: {{ section.settings.bg_color }};
    {% endif %}
  }
</style>

<div class="faq-section-wrapper faq-section-wrapper--{{ section.id }}">
  <div class="faq-container{% unless section.settings.show_image_section %} faq-container--no-image{% endunless %}">
    <div class="faq-left">
      <h2 class="faq-heading">
        <span class="faq-heading-black">{{ section.settings.heading_text_1 }}</span>
        <br>
        <span class="faq-heading-green">{{ section.settings.heading_text_2 }}</span>
      </h2>
      
      <div class="faq-accordion-list">
        {%- for block in section.blocks -%}
          <div class="faq-accordion-item" {{ block.shopify_attributes }}>
            <button class="faq-accordion-header" aria-expanded="false">
              <span class="faq-question">{{ block.settings.question }}</span>
              <span class="faq-icon">
                <svg class="faq-icon-plus" viewBox="0 0 24 24" width="24" height="24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="12" fill="#E8CD54"/>
                  <path d="M12 8v8m-4-4h8" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <svg class="faq-icon-minus" viewBox="0 0 24 24" width="24" height="24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none;">
                  <circle cx="12" cy="12" r="12" fill="#E8CD54"/>
                  <path d="M8 12h8" stroke="#1A1A1A" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
            <div class="faq-accordion-content">
              <div class="faq-answer">{{ block.settings.answer }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
    
    {% if section.settings.show_image_section %}
      <div class="faq-right" style="{% if section.settings.right_bg_color != blank and section.settings.right_bg_color != 'rgba(0,0,0,0)' %}background: {{ section.settings.right_bg_color }};{% endif %}">
        {%- if section.settings.right_image != blank or section.settings.mobile_image != blank -%}
          {%- if section.settings.right_image != blank -%}
            <img src="{{ section.settings.right_image | img_url: 'master' }}" alt="{{ section.settings.right_image.alt | escape }}" class="faq-image faq-image--desktop{% if section.settings.mobile_image == blank %} faq-image--show-all{% endif %}" loading="lazy">
          {%- endif -%}
          {%- if section.settings.mobile_image != blank -%}
            <img src="{{ section.settings.mobile_image | img_url: 'master' }}" alt="{{ section.settings.mobile_image.alt | escape }}" class="faq-image faq-image--mobile{% if section.settings.right_image == blank %} faq-image--show-all{% endif %}" loading="lazy">
          {%- endif -%}
        {%- else -%}
          <div class="faq-image-placeholder">Upload Right Image</div>
        {%- endif -%}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "FAQ with Image",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F7F9F7"
    },
    { 
      "type": "checkbox", 
      "id": "use_gradient_bg", 
      "label": "Use gradient background", 
      "default": false 
    },
    { 
      "type": "color", 
      "id": "bg_gradient_1", 
      "label": "Base Color", 
      "default": "#F7F9F7" 
    },
    { 
      "type": "color", 
      "id": "bg_gradient_2", 
      "label": "Radial Highlight Color", 
      "default": "#F7F9F7" 
    },
    { 
      "type": "color", 
      "id": "bg_gradient_3", 
      "label": "Gradient Accent Color", 
      "default": "#F7F9F7" 
    },
    {
      "type": "text",
      "id": "heading_text_1",
      "label": "Heading Part 1 (Black)",
      "default": "Frequently Asked"
    },
    {
      "type": "text",
      "id": "heading_text_2",
      "label": "Heading Part 2 (Green)",
      "default": "Questions"
    },
    {
      "type": "checkbox",
      "id": "show_image_section",
      "label": "Show Image Section",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Side Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Right Side Image (Mobile)"
    },
    {
      "type": "color_background",
      "id": "right_bg_color",
      "label": "Right Column Background",
      "default": "linear-gradient(180deg, #FFFBF0 0%, #FCE596 50%, #F4C026 100%)"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "WHY IS CALICUT HALWA DIFFERENT FROM OTHER HALWAS?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Provide the answer to your question here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ with Image",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
