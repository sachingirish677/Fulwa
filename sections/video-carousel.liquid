{{ 'video-carousel.css' | asset_url | stylesheet_tag }}
<script src="{{ 'video-carousel.js' | asset_url }}" defer="defer"></script>

<div class="vc-wrapper" style="background-color: {{ section.settings.bg_color }};">
  <div class="vc-header-container">
    {%- if section.settings.mini_header != blank -%}
      <div class="vc-mini-header">
        <span class="vc-mini-line"></span>
        {{ section.settings.mini_header }}
      </div>
    {%- endif -%}
    
    {%- if section.settings.header_1 != blank or section.settings.header_2 != blank -%}
      <h2 class="vc-main-header">
        <span class="vc-header-white">{{ section.settings.header_1 }}</span>
        <span class="vc-header-yellow">{{ section.settings.header_2 }}</span>
      </h2>
    {%- endif -%}
    
    {%- if section.settings.sub_header != blank -%}
      <p class="vc-sub-header">{{ section.settings.sub_header }}</p>
    {%- endif -%}
  </div>

  <div class="vc-slider-container">
    <div class="vc-slider-track">
      {%- for block in section.blocks -%}
        {%- assign video_url = "" -%}
        {%- if block.settings.video != blank -%}
          {%- for source in block.settings.video.sources -%}
            {%- if source.format == 'mp4' -%}
              {%- assign video_url = source.url -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if video_url == blank -%}
            {%- assign video_url = block.settings.video.sources[0].url -%}
          {%- endif -%}
        {%- endif -%}
        <div class="vc-slide {% if forloop.first %}is-active{% endif %}" data-video-url="{{ video_url }}" {{ block.shopify_attributes }}>
          
          <div class="vc-video-wrapper">
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: autoplay: forloop.first, loop: true, muted: true, controls: false, class: 'vc-video-el' }}
            {%- else -%}
              <div class="vc-placeholder-video"></div>
            {%- endif -%}
            <button class="vc-inline-mute" data-vc-inline-mute aria-label="Toggle Sound">
              <svg class="vc-icon-unmute" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
              <svg class="vc-icon-mute" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg>
            </button>
            
            <div class="vc-play-icon">
              <!-- Play Icon (Default) -->
              <svg class="icon-play" width="18" height="22" viewBox="0 0 18 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.5 11L0.5 21V1L17.5 11Z" fill="#ffffff"/>
              </svg>
              <!-- Previous Icon (Left Arrow) -->
              <svg class="icon-prev" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
                <path d="M15 18L9 12L15 6" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <!-- Next Icon (Right Arrow) -->
              <svg class="icon-next" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
                <path d="M9 18L15 12L9 6" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            
            <div class="vc-views-badge">1.2M views</div>
            {%- if block.settings.creator_name != blank -%}
              <div class="vc-author-overlay">@{{ block.settings.creator_name | handleize }}</div>
            {%- endif -%}
          </div>
          
          <div class="vc-details-card">
            <div class="vc-details-inner">
              <h3 class="vc-details-title">{{ block.settings.header }}</h3>
              <div class="vc-details-desc">{{ block.settings.description }}</div>
              
              <div class="vc-creator-info">
                {%- if block.settings.creator_image != blank -%}
                  <img src="{{ block.settings.creator_image | img_url: 'master' }}" class="vc-creator-img" alt="{{ block.settings.creator_name | escape }}">
                {%- else -%}
                  <div class="vc-creator-placeholder"></div>
                {%- endif -%}
                <span class="vc-creator-name">{{ block.settings.creator_name }}</span>
              </div>
              
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="vc-link-overlay" aria-label="View product"></a>
              {%- endif -%}
            </div>
          </div>
          
        </div>
      {%- endfor -%}
    </div>
  </div>

  <!-- Modal -->
  <div class="vc-modal" id="vc-modal-{{ section.id }}" aria-hidden="true">
    <div class="vc-modal__backdrop" data-vc-close></div>
    <div class="vc-modal__content">
      <div class="vc-modal__header">
        <button class="vc-modal__btn vc-modal__minimize" data-vc-close aria-label="Minimize">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14h6v6M20 10h-6V4M14 10l7-7M3 21l7-7"/></svg>
        </button>
        <div class="vc-modal__header-right">
          <button class="vc-modal__btn vc-modal__mute" data-vc-mute aria-label="Toggle Sound">
            <svg class="vc-icon-unmute" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
            <svg class="vc-icon-mute" style="display:none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg>
          </button>
          <button class="vc-modal__btn vc-modal__close" data-vc-close aria-label="Close">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
          </button>
        </div>
      </div>
      
      <button class="vc-modal__nav vc-modal__nav--prev" data-vc-modal-prev aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"></path></svg>
      </button>
      
      <video class="vc-modal__video" id="vc-modal-video-{{ section.id }}" loop playsinline></video>
      
      <button class="vc-modal__nav vc-modal__nav--next" data-vc-modal-next aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"></path></svg>
      </button>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video Carousel",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0D3B16"
    },
    {
      "type": "text",
      "id": "mini_header",
      "label": "Mini Header",
      "default": "HALWA IN YOUR KITCHEN"
    },
    {
      "type": "text",
      "id": "header_1",
      "label": "Header Part 1 (White)",
      "default": "Cook with"
    },
    {
      "type": "text",
      "id": "header_2",
      "label": "Header Part 2 (Yellow)",
      "default": "Calicut"
    },
    {
      "type": "textarea",
      "id": "sub_header",
      "label": "Sub Header",
      "default": "Recipes, pairings, and creative ideas from our community of halwa lovers."
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video (MP4)"
        },
        {
          "type": "text",
          "id": "header",
          "label": "Title",
          "default": "Ramadan dessert"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Must try... Fulva Tender coconut halwa...</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        },
        {
          "type": "image_picker",
          "id": "creator_image",
          "label": "Creator Image"
        },
        {
          "type": "text",
          "id": "creator_name",
          "label": "Creator Name",
          "default": "Arjun Mehta"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Carousel",
      "blocks": [
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" }
      ]
    }
  ]
}
{% endschema %}
