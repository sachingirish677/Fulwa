

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  <div class="footer-custom-layout">
    <div
      class="footer-content spacing-style"
      style="
        --padding-block-start: max(20px, calc(var(--spacing-scale) * 64px));
        --padding-block-end: max(20px, calc(var(--spacing-scale) * 30px));
        --footer-gap: 65.5px;
      "
    >
      {% content_for 'blocks' %}

      <div class="footer-custom-left">
        {% if section.settings.address != blank %}
          <div class="footer-custom-address">
            {{ section.settings.address }}
          </div>
        {% endif %}

        {% if section.settings.fssai_no != blank %}
          <div class="footer-custom-fssai">
            FSSAI LIC No. {{ section.settings.fssai_no }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* ===== FOOTER FLEXBOX LAYOUT ===== */
  .footer-content {
    contain: content;
    content-visibility: auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
    align-items: flex-start;
  }

  .footer-content .menu__heading__default {
    font-weight: var(--font-heading--weight);
  }

  /* ===== DESKTOP: row layout with order-based column grouping ===== */
  @media screen and (min-width: 990px) {
    .footer-content {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0;
      column-gap: 48px;
      row-gap: 24px;
    }

    /* --- Branding column (logo + address) --- */
    .footer-content > .logo-block,
    .footer-content > .image-block {
      order: 1;
      width: 280px;
      flex-shrink: 0;
    }

    .footer-content > .footer-custom-left {
      order: 2;
      width: 280px;
      flex-shrink: 0;
    }

    /* --- Menu columns share remaining space --- */
    .footer-content > .menu {
      order: 3;
      flex: 1 1 0;
      min-width: 120px;
    }
  }

  /* ===== MOBILE: vertical stacking ===== */
  @media screen and (max-width: 989px) {
    .footer-content > .logo-block,
    .footer-content > .image-block {
      order: 1;
      width: 100%;
    }

    .footer-content > .footer-custom-left {
      order: 2;
      width: 100%;
    }

    .footer-content > .menu {
      order: 3;
      width: 100%;
    }
  }

  /* ===== Outer wrapper ===== */
  .footer-custom-layout {
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: relative;
    z-index: 1;
  }

  /* ===== Address & FSSAI ===== */
  .footer-custom-left {
    display: flex;
    flex-direction: column;
    gap: 13.3px;
    max-width: 100%;
  }

  .footer-custom-address {
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-foreground);
    max-width: 320px;
  }

  .footer-custom-address p {
    margin: 0;
  }

  .footer-custom-fssai {
    font-size: 13px;
    color: var(--color-foreground);
    font-weight: 400;
    line-height: 22.75px;
    letter-spacing: 0%;
  }

  /* ===== Menu Styling ===== */
  .footer-custom-layout .menu__heading__default {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #4A7A44;
    margin-bottom: 20px;
    display: block;
  }

  .footer-custom-layout .menu__item a {
    font-size: 13px;
    color: var(--color-foreground);
    text-decoration: none;
    line-height: 1.8;
  }

  .footer-custom-layout .menu__item + .menu__item {
    margin-top: 12px;
  }

  /* ===== Decorative Circle Background ===== */
  .section-wrapper {
    position: relative;
    overflow: hidden;
  }

  .section-wrapper::before {
    content: '';
    position: absolute;
    top: -150px;
    right: -100px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    border: 1px solid rgba(220, 230, 210, 0.4);
    background: radial-gradient(circle, rgba(244, 246, 238, 1) 0%, rgba(244, 246, 238, 0) 70%);
    z-index: 0;
    pointer-events: none;
  }

  @media screen and (min-width: 990px) {
    .section-wrapper {
      max-height: 510.23px;
    }

    .footer-custom-layout {
      padding-inline: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Company Info"
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "Company Address",
      "default": "<p>Authentic Calicut halwa, crafted with tradition and delivered fresh to your door — anywhere in India.</p>"
    },
    {
      "type": "text",
      "id": "fssai_no",
      "label": "FSSAI No",
      "default": "11324999000545"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "color_scheme": "scheme-1",
        "padding-block-start": 36,
        "padding-block-end": 36
      }
    }
  ]
}
{% endschema %}
